---
import '../styles/global.css';
import type { Lang } from '../i18n/ui';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
}
const { title, description = '', lang = 'ru' } = Astro.props;

const site = Astro.site ?? new URL('https://allclean.example');
// Path without the /ro locale prefix, so we can build both alternates.
const basePath = Astro.url.pathname.replace(/^\/ro(?=\/|$)/, '') || '/';
const ruUrl = new URL(basePath, site).href;
const roUrl = new URL('/ro' + (basePath === '/' ? '' : basePath), site).href;
const canonical = lang === 'ru' ? ruUrl : roUrl;
const htmlLang = lang === 'ru' ? 'ru-MD' : 'ro-MD';
---
<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      !(function (o, c) {
        var n = c.documentElement,
          t = ' w-mod-';
        n.className += t + 'js';
        ('ontouchstart' in o || (o.DocumentTouch && c instanceof DocumentTouch)) &&
          (n.className += t + 'touch');
      })(window, document);
    </script>
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="ru-MD" href={ruUrl} />
    <link rel="alternate" hreflang="ro-MD" href={roUrl} />
    <link rel="alternate" hreflang="x-default" href={ruUrl} />
    <slot name="head" />
  </head>
  <body>
    <slot />
    <script
      src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=692f17afc3743c9cd4b7cac6"
      is:inline></script>
    <script src="https://cdn.prod.website-files.com/692f17afc3743c9cd4b7cac6/js/webflow.schunk.36b8fb49256177c8.js" is:inline></script>
    <script src="https://cdn.prod.website-files.com/692f17afc3743c9cd4b7cac6/js/webflow.schunk.bc23d7c65c944c69.js" is:inline></script>
    <script src="https://cdn.prod.website-files.com/692f17afc3743c9cd4b7cac6/js/webflow.schunk.121b0d7ff03e0f4a.js" is:inline></script>
    <script src="https://cdn.prod.website-files.com/692f17afc3743c9cd4b7cac6/js/webflow.95894b5d.ec85210f88b23bb1.js" is:inline></script>
    <script src="https://cdn.prod.website-files.com/gsap/3.15.0/gsap.min.js" is:inline></script>
    <script src="https://cdn.prod.website-files.com/gsap/3.15.0/ScrollTrigger.min.js" is:inline></script>
    <script is:inline>window.gsap && gsap.registerPlugin(ScrollTrigger);</script>
    <script is:inline>
      window.addEventListener('load', function () {
        if (!window.gsap || !document.querySelector('[data-marquee-part]')) return;
        gsap.set('[data-marquee-inner]', { xPercent: -50 });
        var tween = gsap.to('[data-marquee-part]', { xPercent: -100, repeat: -1, duration: 45, ease: 'linear' });
        document.querySelectorAll('[data-marquee-inner]').forEach(function (m) {
          m.addEventListener('mouseenter', function () { gsap.to(tween, { timeScale: 0.3, duration: 0.5, ease: 'power1.out' }); });
          m.addEventListener('mouseleave', function () { gsap.to(tween, { timeScale: 1, duration: 0.5, ease: 'power1.in' }); });
        });
      });
    </script>
  </body>
</html>
