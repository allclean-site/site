---
import '../styles/global.css';
import type { Lang } from '../i18n/ui';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
  // Optional alternate overrides — used by blog articles, where RU and RO slugs differ.
  ruAlternate?: string;
  roAlternate?: string;
  ogImage?: string;
}
const { title, description = '', lang = 'ru', ruAlternate, roAlternate, ogImage } = Astro.props;

const site = Astro.site ?? new URL('https://allclean.example');
// Path without the /ro locale prefix, so we can build both alternates.
const basePath = Astro.url.pathname.replace(/^\/ro(?=\/|$)/, '') || '/';
const ruUrl = ruAlternate ?? new URL(basePath, site).href;
const roUrl = roAlternate ?? new URL('/ro' + (basePath === '/' ? '' : basePath), site).href;
const canonical = lang === 'ru' ? ruUrl : roUrl;
const htmlLang = lang === 'ru' ? 'ru-MD' : 'ro-MD';
const ogImg = ogImage ?? 'https://cdn.prod.website-files.com/692f17afc3743c9cd4b7cac6%2F693817393d800624450974eb_hero%20%281%29_poster.0000000.jpg';
const ogLocale = lang === 'ru' ? 'ru_MD' : 'ro_MD';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'All Clean',
  description: 'Профессиональная клининговая служба в Кишинёве: уборка квартир, домов, офисов и коммерческих помещений.',
  url: site.href,
  telephone: '+37379955044',
  email: 'info@allclean.md',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'ул. Месаджер, 7',
    addressLocality: 'Кишинёв',
    postalCode: 'MD-2069',
    addressCountry: 'MD',
  },
  areaServed: 'Кишинёв',
  priceRange: '$$',
  openingHours: 'Mo-Su 08:00-21:00',
};
---
<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://cdn.prod.website-files.com" crossorigin />
    <link rel="preconnect" href="https://hbdjboimxqwkzxntidzt.supabase.co" crossorigin />
    <link rel="dns-prefetch" href="https://cdn.prod.website-files.com" />
    <script is:inline>
      !(function (o, c) {
        var n = c.documentElement,
          t = ' w-mod-';
        n.className += t + 'js';
        ('ontouchstart' in o || (o.DocumentTouch && c instanceof DocumentTouch)) &&
          (n.className += t + 'touch');
      })(window, document);
    </script>
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="ru-MD" href={ruUrl} />
    <link rel="alternate" hreflang="ro-MD" href={roUrl} />
    <link rel="alternate" hreflang="x-default" href={ruUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="All Clean" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImg} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImg} />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} is:inline />
    <slot name="head" />
  </head>
  <body>
    <slot />
    <script is:inline>
      /* Visual editor loads only when the URL has ?lgedit — public pages stay clean/fast. */
      if (/[?&#]lgedit\b/.test(location.search + location.hash)) {
        var s = document.createElement('script'); s.src = '/editor.js?v=10'; document.body.appendChild(s);
      }
    </script>
    <script
      src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=692f17afc3743c9cd4b7cac6"
      is:inline></script>
    <script src="https://cdn.prod.website-files.com/692f17afc3743c9cd4b7cac6/js/webflow.schunk.36b8fb49256177c8.js" is:inline></script>
    <script src="https://cdn.prod.website-files.com/692f17afc3743c9cd4b7cac6/js/webflow.schunk.bc23d7c65c944c69.js" is:inline></script>
    <script src="https://cdn.prod.website-files.com/692f17afc3743c9cd4b7cac6/js/webflow.schunk.121b0d7ff03e0f4a.js" is:inline></script>
    <script src="https://cdn.prod.website-files.com/692f17afc3743c9cd4b7cac6/js/webflow.95894b5d.ec85210f88b23bb1.js" is:inline></script>
    <script src="https://cdn.prod.website-files.com/gsap/3.15.0/gsap.min.js" is:inline></script>
    <script src="https://cdn.prod.website-files.com/gsap/3.15.0/ScrollTrigger.min.js" is:inline></script>
    <script is:inline>window.gsap && gsap.registerPlugin(ScrollTrigger);</script>
    <script is:inline>
      window.addEventListener('load', function () {
        if (!window.gsap || !document.querySelector('[data-marquee-part]')) return;
        gsap.set('[data-marquee-inner]', { xPercent: -50 });
        var tween = gsap.to('[data-marquee-part]', { xPercent: -100, repeat: -1, duration: 45, ease: 'linear' });
        document.querySelectorAll('[data-marquee-inner]').forEach(function (m) {
          m.addEventListener('mouseenter', function () { gsap.to(tween, { timeScale: 0.3, duration: 0.5, ease: 'power1.out' }); });
          m.addEventListener('mouseleave', function () { gsap.to(tween, { timeScale: 1, duration: 0.5, ease: 'power1.in' }); });
        });
      });
    </script>
  </body>
</html>
