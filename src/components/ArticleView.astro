---
import { marked } from 'marked';
import type { Article, Locale } from '../lib/articles';

interface Props {
  article: Article;
  locale: Locale;
}
const { article, locale } = Astro.props;
const html = article.body ? await marked.parse(article.body) : '';
const backHref = locale === 'ru' ? '/blog' : '/ro/blog';
const t =
  locale === 'ru'
    ? { back: '← Все статьи', takeaways: 'Коротко о главном', faq: 'Частые вопросы' }
    : { back: '← Toate articolele', takeaways: 'Pe scurt', faq: 'Întrebări frecvente' };
const fmt = (d: string) =>
  new Date(d).toLocaleDateString(locale === 'ru' ? 'ru-RU' : 'ro-RO', { day: 'numeric', month: 'long', year: 'numeric' });
const takeaways = article.meta?.takeaways ?? [];
const faq = article.meta?.faq ?? [];
---
<article class="post">
  <a class="post-back" href={backHref}>{t.back}</a>
  <h1>{article.title}</h1>
  <time class="post-date">{fmt(article.created_at)}</time>
  {article.cover_url && <img class="post-cover" src={article.cover_url} alt={article.title} />}

  {takeaways.length > 0 && (
    <aside class="post-takeaways">
      <h2>{t.takeaways}</h2>
      <ul>{takeaways.map((x) => <li>{x}</li>)}</ul>
    </aside>
  )}

  <div class="post-body" set:html={html} />

  {article.image2_url && <img class="post-img2" src={article.image2_url} alt={article.title} />}

  {faq.length > 0 && (
    <section class="post-faq">
      <h2>{t.faq}</h2>
      {faq.map((f) => (
        <details>
          <summary>{f.question}</summary>
          <p>{f.answer}</p>
        </details>
      ))}
    </section>
  )}
</article>
<style>
  .post { max-width: 760px; margin: 0 auto; padding: 64px 24px 90px; color: #1c2b47; }
  .post-back { color: #2b6cf6; text-decoration: none; font-weight: 600; font-size: .95rem; }
  .post h1 { color: #0c2959; font-size: clamp(1.9rem, 4.5vw, 2.8rem); line-height: 1.2; margin: 20px 0 10px; }
  .post-date { color: #8a99b5; font-size: .9rem; }
  .post-cover { width: 100%; max-height: 440px; object-fit: cover; border-radius: 18px; margin: 24px 0 8px; }
  .post-takeaways { background: #eef3fd; border: 1px solid #dbe6fb; border-radius: 16px; padding: 22px 24px; margin: 28px 0; }
  .post-takeaways h2 { color: #0c2959; font-size: 1.15rem; margin: 0 0 12px; }
  .post-takeaways ul { margin: 0; padding-left: 20px; }
  .post-takeaways li { color: #2f3e5c; margin: 7px 0; line-height: 1.5; }
  .post-body { font-size: 1.08rem; line-height: 1.75; color: #2f3e5c; }
  .post-body :global(h2) { color: #0c2959; font-size: 1.5rem; margin: 36px 0 12px; }
  .post-body :global(h3) { color: #0c2959; font-size: 1.2rem; margin: 28px 0 10px; }
  .post-body :global(p) { margin: 16px 0; }
  .post-body :global(ul), .post-body :global(ol) { padding-left: 22px; margin: 16px 0; }
  .post-body :global(li) { margin: 8px 0; }
  .post-body :global(a) { color: #2b6cf6; }
  .post-body :global(img) { max-width: 100%; border-radius: 12px; }
  .post-img2 { width: 100%; max-height: 440px; object-fit: cover; border-radius: 18px; margin: 28px 0; }
  .post-faq { margin-top: 48px; border-top: 1px solid #e6ecf7; padding-top: 32px; }
  .post-faq h2 { color: #0c2959; font-size: 1.6rem; margin: 0 0 18px; }
  .post-faq details { border: 1px solid #e6ecf7; border-radius: 12px; padding: 14px 18px; margin: 10px 0; background: #fff; }
  .post-faq summary { cursor: pointer; font-weight: 600; color: #0c2959; }
  .post-faq p { color: #5b6b8c; margin: 12px 0 2px; line-height: 1.6; }
</style>
