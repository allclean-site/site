                <div class="form-block_contact w-form">
                  <form
                    id="wf-form-Contact-Form"
                    name="wf-form-Contact-Form"
                    data-name="Contact Form"
                    method="get"
                    class="form_block"
                    data-wf-page-id="6937004b038c1c63ed54e1af"
                    data-wf-element-id="a851613a-6b99-d5d2-b928-b5959337d737"
                  >
                    <div class="contact-form_top-tile">
                      <h2 class="heading-style-h5 margin-0">
                        Запишитесь онлайн за 60 секунд
                      </h2>
                      <div class="text-size-small tone-medium">
                        Для тех, кто любит мгновенную запись.
                      </div>
                    </div>
                    <div class="contact-form_center-tile">
                      <div class="contact-form_inner">
                        <div class="w-layout-grid input_halves">
                          <div class="input_wrap">
                            <div class="label-large text-input-label">Name</div>
                            <input
                              class="text-field w-input"
                              maxlength="256"
                              name="name"
                              data-name="Name"
                              placeholder="John Doe"
                              type="text"
                              id="name"
                              required=""
                            />
                          </div>
                          <div class="input_wrap">
                            <div class="label-large text-input-label">
                              Phone (required)
                            </div>
                            <input
                              class="text-field w-input"
                              maxlength="256"
                              name="Phone"
                              data-name="Phone"
                              placeholder="+1 23 456 789"
                              type="tel"
                              id="Phone"
                              required=""
                            />
                          </div>
                        </div>
                        <div
                          id="w-node-a851613a-6b99-d5d2-b928-b5959337d748-ed54e1af"
                          class="input_wrap"
                        >
                          <div class="label-large text-input-label">
                            Тип услуги
                          </div>
                          <div class="input-relative">
                            <select
                              id="Service-type"
                              name="Service-type"
                              data-name="Тип услуги"
                              class="text-field select w-select"
                            >
                              <option value="">Уборка квартиры</option>
                              <option value="First">Вариант 1</option>
                              <option value="Second">Вариант 2</option>
                              <option value="Third">Вариант 3</option>
                            </select>
                            <div class="select_overlay">
                              <div class="icon_select w-embed">
                                <svg
                                  width="100%"
                                  height="100%"
                                  viewBox="0 0 20 20"
                                  fill="none"
                                  xmlns="http://www.w3.org/2000/svg"
                                >
                                  <path
                                    d="M5 7.5L10 12.5L15 7.5"
                                    stroke="currentColor"
                                    stroke-width="var(--_❇️-icon---icon-stroke)"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                  />
                                </svg>
                              </div>
                            </div>
                          </div>
                        </div>
                        <div class="input_wrap">
                          <div class="label-large text-input-label">
                            Количество комнат
                          </div>
                          <div class="input-relative">
                            <select
                              id="Number-of-bedrooms"
                              name="Number-of-bedrooms"
                              data-name="Количество комнат"
                              class="text-field select w-select"
                            >
                              <option value="">1 комната</option>
                              <option value="First">Вариант 1</option>
                              <option value="Second">Вариант 2</option>
                              <option value="Third">Вариант 3</option>
                            </select>
                            <div class="select_overlay">
                              <div class="icon_select w-embed">
                                <svg
                                  width="100%"
                                  height="100%"
                                  viewBox="0 0 20 20"
                                  fill="none"
                                  xmlns="http://www.w3.org/2000/svg"
                                >
                                  <path
                                    d="M5 7.5L10 12.5L15 7.5"
                                    stroke="currentColor"
                                    stroke-width="var(--_❇️-icon---icon-stroke)"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                  />
                                </svg>
                              </div>
                            </div>
                          </div>
                        </div>
                        <div class="input_wrap">
                          <div class="label-large text-input-label">Notes</div>
                          <textarea
                            id="Message"
                            name="Message"
                            maxlength="5000"
                            data-name="Message"
                            placeholder="Optional"
                            class="text-field textarea w-input"
                          ></textarea>
                        </div>
