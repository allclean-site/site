---
// Language switcher — single on/off-style toggle (not two separate buttons). Default/"off"
// position is Romanian (Moldova flag, thumb on the left); pressing it goes to Russian
// (Russia flag, thumb slides to the right). Used in Header (desktop bar + mobile menu) and Footer.
// altHref, when given, is the EXACT other-language URL for this page (blog posts have
// per-article RU/RO slugs that can differ — pages that know the real counterpart pass it
// in). Otherwise falls back to a plain /ro prefix swap, correct for every non-blog page.
interface Props { lang?: 'ru' | 'ro'; altHref?: string; place?: string }
const { lang = 'ru', altHref, place = 'x' } = Astro.props;
const basePath = Astro.url.pathname.replace(/^\/ro(?=\/|$)/, '') || '/';
const roPath = '/ro' + (basePath === '/' ? '' : basePath);
const isRo = lang === 'ro';
// Clicking always goes to the OTHER language.
const targetHref = isRo ? (altHref || basePath) : (altHref || roPath);
// SVG <clipPath> ids must be unique per document — this component renders in Header (desktop
// + mobile) and Footer, so a fixed id would collide across instances on the same page.
const idMd = `flag-md-${place}`;
const idRu = `flag-ru-${place}`;
---
<a href={targetHref} class={"lang-toggle" + (isRo ? ' is-ro' : ' is-ru')} title={isRo ? 'Comută pe rusă' : 'Переключить на румынский'}>
  <span class="lang-toggle_track">
    <span class="lang-toggle_thumb">
      {isRo ? (
        <svg viewBox="0 0 20 20" width="20" height="20" aria-hidden="true">
          <defs><clipPath id={idMd}><circle cx="10" cy="10" r="10"/></clipPath></defs>
          <g clip-path={`url(#${idMd})`}>
            <rect width="6.9" height="20" fill="#003DA5"/>
            <rect x="6.9" width="6.2" height="20" fill="#FFD200"/>
            <rect x="13.1" width="6.9" height="20" fill="#CC092F"/>
            <circle cx="10" cy="10" r="2.1" fill="#8B4513"/>
          </g>
        </svg>
      ) : (
        <svg viewBox="0 0 20 20" width="20" height="20" aria-hidden="true">
          <defs><clipPath id={idRu}><circle cx="10" cy="10" r="10"/></clipPath></defs>
          <g clip-path={`url(#${idRu})`}>
            <rect width="20" height="6.67" fill="#fff"/>
            <rect y="6.67" width="20" height="6.67" fill="#0039A6"/>
            <rect y="13.33" width="20" height="6.67" fill="#D52B1E"/>
          </g>
        </svg>
      )}
    </span>
    <span class="lang-toggle_label">{isRo ? 'RO' : 'RU'}</span>
  </span>
</a>
<style>
  .lang-toggle { display: inline-flex; text-decoration: none; }
  .lang-toggle_track {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 3px;
    border-radius: 999px;
    background: rgba(12, 41, 89, 0.06);
    box-shadow: inset 0 1px 3px rgba(12, 41, 89, 0.12);
    transition: background-color .2s ease;
  }
  .lang-toggle:hover .lang-toggle_track { background: rgba(12, 41, 89, 0.1); }
  .lang-toggle_thumb {
    display: flex; align-items: center; justify-content: center;
    width: 22px; height: 22px; border-radius: 50%;
    background: #fff;
    box-shadow: 0 1px 3px rgba(12, 41, 89, 0.35);
    flex: none;
    order: 1;
  }
  .lang-toggle_label {
    font-size: 12px; font-weight: 700; color: #0c2959; line-height: 1;
    padding: 0 8px 0 2px;
    order: 2;
  }
  /* "off" (Romanian, default): thumb on the left, label on the right. */
  .lang-toggle.is-ro .lang-toggle_thumb { order: 1; }
  .lang-toggle.is-ro .lang-toggle_label { order: 2; padding: 0 8px 0 2px; }
  /* "on" (Russian): thumb slides to the right, label moves to the left. */
  .lang-toggle.is-ru .lang-toggle_thumb { order: 2; }
  .lang-toggle.is-ru .lang-toggle_label { order: 1; padding: 0 2px 0 8px; }
</style>
