---
// Testimonials — data-driven marquee (3 columns). Design identical to the original
// All Clean (home) block; only the review texts/heading are now props so service
// pages can show relevant reviews. Defaults reproduce the homepage exactly.
const DEFAULT_ITEMS = [
  '“Я мама двоих детей, и дома быстро становится беспорядок. Пробовала разные службы — делали по минимуму. С All Clean всё иначе: наконец-то не нужно ничего перепроверять.”',
  '“Возвращаться домой после их уборки — отдельное удовольствие. В квартире будто становится легче дышать и просторнее.”',
  '“Прихожу домой после уборки — как будто заехала в новую квартиру. Чисто, свежо и всё на своих местах.”',
  '“Именно то, что было нужно после сумасшедшей недели.”',
  '“Быстро, вежливо и невероятно тщательно.”',
  '“Честно, сомневалась, что найду нормальный клининг в Кишинёве — раньше все либо спешили, либо халтурили. Эта команда удивила: всё аккуратно, по полочкам, даже маленькую квартиру преобразили.”',
  '“Моя квартира никогда не выглядела такой ухоженной.”',
  '“Справились с пылью после ремонта как профессионалы — ни пылинки в углах.”',
  '“Используют натуральные средства — это важно при моей аллергии. Дома пахнет чистотой, а не химией.”',
];

interface Props {
  items?: string[];
  heading?: string;
  label?: string;
  reviewLabel?: string;
  allLabel?: string;
  lang?: 'ru' | 'ro';
}
const {
  items = DEFAULT_ITEMS,
  heading = 'НАМ ДОВЕРЯЮТ · РЕЙТИНГ 4.9/5',
  label = 'Отзывы',
  reviewLabel = 'Отзыв в Google',
  allLabel = 'Все отзывы',
  lang = 'ru',
} = Astro.props;
const base = lang === 'ro' ? '/ro' : '';

// distribute into 3 columns (sequential thirds)
const list = items.length ? items : DEFAULT_ITEMS;
const per = Math.ceil(list.length / 3);
const columns = [list.slice(0, per), list.slice(per, per * 2), list.slice(per * 2)].map((c) => (c.length ? c : list.slice(0, 1)));
const colSuffix = ['', ' _2nd', ' _3rd'];
// Mobile: the desktop 3-column animated marquee is hidden outright at ≤767px (sparkles.css
// `.marquee-thirds{display:none}`) with nothing shown in its place — no reviews at all on phones.
// Below is a simple flat mobile-only list (shown only via CSS at ≤767px): first 2 reviews visible,
// the rest revealed by a "Показать ещё" toggle.
const moreLabel = lang === 'ro' ? 'Arată mai multe' : 'Показать ещё';
const MOBILE_VISIBLE = 2;
---
<section class="section_home-testimonials">
  <div class="padding-global">
    <div class="w-layout-blockcontainer container-large w-container">
      <div data-w-id="40ce0cb9-0472-af2a-714a-61e17169d12c" style="opacity:1" class="headline_testimonials">
        <div data-wf--tag--variant="depth" class="master_label w-variant-9a59c277-b838-5a8e-f25e-39f9204dca4d">
          <div class="label-large">{label}</div>
        </div>
        <h2 class="margin-0">{heading}</h2>
        <a href={base + '/about'} button="" class="cta_primary secondary w-inline-block">
          <div class="icon-google-btn w-embed">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M14.0742 9.18518V12.1481C14.0742 13.3997 13.0889 14.6666 11.2054 14.6666H8.77439C5.16825 14.6666 2.16632 11.9322 1.94039 8.44132C1.81452 6.50225 2.50559 4.66019 3.88132 3.28265C5.17445 1.98779 6.97759 1.33325 8.80752 1.33325H12.6666C13.0348 1.33325 13.3333 1.63172 13.3333 1.99992V3.33325C13.3333 3.70139 13.0348 3.99992 12.6666 3.99992H8.73872C7.70679 3.99985 6.68065 4.33319 5.91625 5.02645C4.99085 5.86565 4.52125 7.03392 4.60112 8.26878C4.73685 10.3609 6.56985 11.9999 8.77432 11.9999C8.77432 11.9999 9.96665 11.9965 10.7469 11.9914C11.1133 11.9891 11.4075 11.6912 11.4075 11.3247V9.99992C11.4075 9.63172 11.109 9.33325 10.7408 9.33325H8.66659C8.29839 9.33325 7.99992 9.03472 7.99992 8.66658V7.33325C7.99992 6.96505 8.29839 6.66658 8.66659 6.66658H11.5556C12.9465 6.66658 14.0742 7.79425 14.0742 9.18518Z" fill="#537FDD"></path>
            </svg>
          </div>
          <div class="button_text-mask secondary">
            <div button-text="" class="text-button secondary">{allLabel}</div>
          </div>
          <div button-bg="" class="btn-bg secondary"></div>
        </a>
      </div>
      <div data-w-id="1fdfd081-920c-709d-428c-0731e9c0e6e5" style="opacity:1" class="w-layout-grid marquee-thirds">
        {columns.map((col, ci) => (
          <div class={'marquee-vertical first' + colSuffix[ci]}>
            <div class="marquee_testimonials">
              {[0, 1].map(() => (
                <div class="single-marquee-testimonials">
                  {col.map((text) => (
                    <div class="card_testimonial-marquee">
                      <div class="testimonial_top-tile">
                        <div class="testimonial-rating">
                          {[0, 1, 2, 3, 4].map(() => (
                            <div class="icon-star w-embed">
                              <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 16 16" fill="none">
                                <path d="M9.69824 5.26074C9.84349 5.5561 10.1255 5.76082 10.4512 5.80859L14.2598 6.36719L11.502 9.06348C11.2674 9.293 11.1606 9.62275 11.2158 9.94629L11.8652 13.752L8.46387 11.957C8.17179 11.8029 7.82233 11.8029 7.53027 11.957L4.12891 13.752L4.7793 9.94629C4.8345 9.62285 4.72764 9.29298 4.49316 9.06348L1.73535 6.36719L5.54395 5.80859C5.86948 5.76081 6.15062 5.55594 6.2959 5.26074L7.99707 1.80078L9.69824 5.26074Z" fill="currentColor" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path>
                              </svg>
                            </div>
                          ))}
                        </div>
                        <div class="text-size-large">{text}</div>
                      </div>
                      <div class="text_body-bold">{reviewLabel}</div>
                    </div>
                  ))}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
      <div class="mobile-testimonials">
        {list.map((text, i) => (
          <div class={'mt-item' + (i >= MOBILE_VISIBLE ? ' mt-extra' : '')}>
            <div class="card_testimonial-marquee">
              <div class="testimonial_top-tile">
                <div class="testimonial-rating">
                  {[0, 1, 2, 3, 4].map(() => (
                    <div class="icon-star w-embed">
                      <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 16 16" fill="none">
                        <path d="M9.69824 5.26074C9.84349 5.5561 10.1255 5.76082 10.4512 5.80859L14.2598 6.36719L11.502 9.06348C11.2674 9.293 11.1606 9.62275 11.2158 9.94629L11.8652 13.752L8.46387 11.957C8.17179 11.8029 7.82233 11.8029 7.53027 11.957L4.12891 13.752L4.7793 9.94629C4.8345 9.62285 4.72764 9.29298 4.49316 9.06348L1.73535 6.36719L5.54395 5.80859C5.86948 5.76081 6.15062 5.55594 6.2959 5.26074L7.99707 1.80078L9.69824 5.26074Z" fill="currentColor" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path>
                      </svg>
                    </div>
                  ))}
                </div>
                <div class="text-size-large">{text}</div>
              </div>
              <div class="text_body-bold">{reviewLabel}</div>
            </div>
          </div>
        ))}
        {list.length > MOBILE_VISIBLE && (
          <button type="button" class="mt-more">{moreLabel}</button>
        )}
      </div>
    </div>
  </div>
</section>
<style>
  .mobile-testimonials { display: none; }
  @media (max-width: 767px) {
    .mobile-testimonials { display: flex; flex-direction: column; gap: 16px; margin-top: 24px; }
    .mobile-testimonials .mt-extra { display: none; }
    .mobile-testimonials.is-open .mt-extra { display: block; }
    .mobile-testimonials .card_testimonial-marquee { width: 100%; }
    .mobile-testimonials .mt-more {
      margin-top: 4px; padding: 14px; border-radius: 12px; border: 1px solid #cdddfb;
      background: #eef3fd; color: #0c2959; font-weight: 700; font-size: 15px; cursor: pointer;
    }
    .mobile-testimonials .mt-more:hover { background: #dbe6fb; }
  }
</style>
<script>
  document.querySelectorAll('.mobile-testimonials .mt-more').forEach((btn) => {
    btn.addEventListener('click', () => {
      const wrap = btn.closest('.mobile-testimonials');
      wrap?.classList.add('is-open');
      btn.style.display = 'none';
    });
  });
</script>
