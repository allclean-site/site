---
// AboutSection — lifted from All Clean (home).
---
        <section class="section_home-about">
          <div class="padding-global">
            <div class="w-layout-blockcontainer container-large w-container">
              <div class="master_home-about">
                <div class="image-wrap_home-team">
                  <img
                    src="https://cdn.prod.website-files.com/692f17afc3743c9cd4b7cac6/69386b7592e7012916c99511_home-cta-image.avif"
                    loading="lazy"
                    sizes="(max-width: 767px) 100vw, (max-width: 991px) 728px, 940px"
                    srcset="
                      https://cdn.prod.website-files.com/692f17afc3743c9cd4b7cac6/69386b7592e7012916c99511_home-cta-image-p-500.avif   500w,
                      https://cdn.prod.website-files.com/692f17afc3743c9cd4b7cac6/69386b7592e7012916c99511_home-cta-image-p-800.avif   800w,
                      https://cdn.prod.website-files.com/692f17afc3743c9cd4b7cac6/69386b7592e7012916c99511_home-cta-image-p-1080.avif 1080w,
                      https://cdn.prod.website-files.com/692f17afc3743c9cd4b7cac6/69386b7592e7012916c99511_home-cta-image.avif        2064w
                    "
                    alt="Group of six smiling cleaning staff in beige uniforms holding cleaning supplies in a bright living room."
                    class="image_cover"
                  />
                </div>
                <div class="content_home-about">
                  <div data-wf--tag--variant="base" class="master_label">
                    <div class="label-large">Meet the team</div>
                  </div>
                  <h2 class="heading-style-h3 margin-0">
                    Наши клинеры проверены, обучены и застрахованы. Вы всегда знаете, кто придёт к вам домой.
                  </h2>
                  <a
                    href="/about"
                    button=""
                    data-wf--cta-primary--variant="secondary"
                    class="cta_primary w-variant-1ff8d96e-78cc-eac8-de90-206ecdaded5f w-inline-block"
                    ><div class="button_text-mask">
                      <div button-icon-right="" class="icon-wrap_button">
                        <div class="wrap_icon-btn">
                          <div class="icon_button w-embed">
                            <svg
                              width="100%"
                              height="100%"
                              viewBox="0 0 16 16"
                              fill="none"
                              xmlns="http://www.w3.org/2000/svg"
                            >
                              <path
                                d="M3.33337 8.00016H12.6667M12.6667 8.00016L8.00004 3.3335M12.6667 8.00016L8.00004 12.6668"
                                stroke="currentColor"
                                stroke-width="var(--_❇️-icon---icon-stroke)"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                              />
                            </svg>
                          </div>
                        </div>
                      </div>
                      <div button-text="" class="text-button">About us</div>
                    </div>
                    <div
                      button-bg=""
                      class="btn-bg w-variant-1ff8d96e-78cc-eac8-de90-206ecdaded5f"
                    ></div
                  ></a>
                </div>
              </div>
            </div>
          </div>
        </section>
