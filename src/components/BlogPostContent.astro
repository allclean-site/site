---
import { marked } from 'marked';
import type { Article, Locale } from '../lib/articles';

interface Props {
  article: Article;
  locale: Locale;
}
const { article, locale } = Astro.props;
// The Sparkles rich-text design styles body subheads as h5/h6; Markdown ## would render huge h2,
// so downshift heading levels (h1→h4, h2→h5, h3→h6) to match the template.
let html = article.body ? await marked.parse(article.body) : '';
html = html
  .replace(/<(\/?)h1(\b[^>]*)>/g, '<$1h4$2>')
  .replace(/<(\/?)h2(\b[^>]*)>/g, '<$1h5$2>')
  .replace(/<(\/?)h3(\b[^>]*)>/g, '<$1h6$2>');
const p = locale === 'ru' ? '' : '/ro';
const t =
  locale === 'ru'
    ? { faq: 'Частые вопросы', ctaH: 'ГОТОВЫ К ЧИСТОМУ И СПОКОЙНОМУ ДОМУ?', ctaSub: 'Закажите проверенных клинеров, которые приезжают вовремя, работают с заботой и оставляют дом свежим.', book: 'Записаться на уборку', price: 'Смотреть цены' }
    : { faq: 'Întrebări frecvente', ctaH: 'GATA PENTRU O CASĂ CURATĂ ȘI LINIȘTITĂ?', ctaSub: 'Rezervă curățători de încredere care vin la timp, lucrează cu grijă și îți lasă casa proaspătă.', book: 'Programează curățenia', price: 'Vezi prețuri' };
const fmt = (d: string) =>
  new Date(d).toLocaleDateString(locale === 'ru' ? 'ru-RU' : 'ro-RO', { day: 'numeric', month: 'long', year: 'numeric' });
const faq = article.meta?.faq ?? [];
---
<main class="main-wrapper">
  <section class="section_hero-article">
    <div class="padding-global">
      <div class="w-layout-blockcontainer container-large w-container">
        <div class="headline_article">
          <div class="label-large">{fmt(article.created_at)}</div>
          <h1>{article.title}</h1>
        </div>
        {article.cover_url && (
          <div class="image-wrap_hero-article">
            <img src={article.cover_url} loading="eager" alt={article.title} sizes="100vw" class="image_cover" />
          </div>
        )}
        <div class="master_body-article">
          <div class="wrap_6-center">
            <div class="body_article w-richtext" set:html={html} />
          </div>

          {article.image2_url && (
            <div class="body_article w-richtext">
              <figure class="w-richtext-align-fullwidth w-richtext-figure-type-image">
                <div><img src={article.image2_url} loading="lazy" alt={article.title} /></div>
              </figure>
            </div>
          )}

          {faq.length > 0 && (
            <div class="wrap_6-center">
              <div class="wrap_faq-block" style="opacity:1">
                <div class="headline_faq-block">
                  <h2 class="heading-style-h4 margin-0">{t.faq}</h2>
                </div>
                <div class="faq-block blog-faq">
                  {faq.map((f) => (
                    <div class="expandable-single">
                      <div class="expandable-top">
                        <div class="text-size-large text_body-bold">{f.question}</div>
                        <div class="faq_animated-box">
                          <div class="faq-horizontal"></div>
                          <div class="faq-vertical"></div>
                        </div>
                      </div>
                      <div class="expandable-bottom">
                        <p class="faq-paragraph">{f.answer}</p>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
</main>
<section class="section_cta">
  <div class="padding-global">
    <div class="w-layout-blockcontainer container-large w-container">
      <div class="master_cta">
        <div class="content_cta">
          <h2>{t.ctaH}</h2>
          <div class="subtext_cta">
            <p class="text-size-large">{t.ctaSub}</p>
          </div>
          <div class="button-group_center">
            <a href={p + '/book-cleaning'} button="" data-wf--cta-primary--variant="lift" class="cta_primary w-inline-block">
              <div class="button_text-mask">
                <div button-icon-right="" class="icon-wrap_button">
                  <div class="wrap_icon-btn">
                    <div class="icon_button w-embed">
                      <svg width="100%" height="100%" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M3.33337 8.00016H12.6667M12.6667 8.00016L8.00004 3.3335M12.6667 8.00016L8.00004 12.6668" stroke="currentColor" stroke-width="var(--_❇️-icon---icon-stroke)" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </div>
                  </div>
                </div>
                <div button-text="" class="text-button">{t.book}</div>
              </div>
              <div button-bg="" class="btn-bg w-variant-f3c49ac3-5f19-afad-90be-3c82d51179b6"></div>
            </a>
            <a href={p + '/pricing'} button="" data-wf--cta-primary--variant="secondary" class="cta_primary w-variant-1ff8d96e-78cc-eac8-de90-206ecdaded5f w-inline-block">
              <div class="button_text-mask">
                <div button-icon-right="" class="icon-wrap_button">
                  <div class="wrap_icon-btn">
                    <div class="icon_button w-embed">
                      <svg width="100%" height="100%" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M3.33337 8.00016H12.6667M12.6667 8.00016L8.00004 3.3335M12.6667 8.00016L8.00004 12.6668" stroke="currentColor" stroke-width="var(--_❇️-icon---icon-stroke)" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </div>
                  </div>
                </div>
                <div button-text="" class="text-button">{t.price}</div>
              </div>
              <div button-bg="" class="btn-bg w-variant-1ff8d96e-78cc-eac8-de90-206ecdaded5f"></div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Sparkles FAQ accordion behaviour for the blog post (Webflow IX isn't bound on this custom page) */
  .blog-faq .expandable-top { cursor: pointer; }
  .blog-faq .expandable-bottom { max-height: 0; transition: max-height .4s ease; }
  .blog-faq .expandable-single.is-open .expandable-bottom { max-height: 1000px; }
  .blog-faq .faq-vertical { transition: transform .3s ease; }
  .blog-faq .expandable-single.is-open .faq-vertical { transform: rotate(90deg); opacity: 0; }
</style>
<script>
  document.querySelectorAll('.blog-faq .expandable-top').forEach((top) => {
    top.addEventListener('click', () => {
      top.closest('.expandable-single')?.classList.toggle('is-open');
    });
  });
</script>
