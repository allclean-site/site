    </div>
    <div class="text-wrap_support-tile">
      <div class="heading-style-h5">Позвонить</div>
      <div>+373 79 955 044</div>
    </div></a
  ><a href="https://api.whatsapp.com/send?phone=37379955044" class="book_support-item w-inline-block"
    ><div class="icon-wrap_feature">
      <div class="icon-feature w-embed">
        <img
          src={`${STORAGE_URL}/article-images/allclean/site/1783062470768-6ebuvv.svg`}
          alt=""
          style="width: 100%; height: 100%; object-fit: contain;"
