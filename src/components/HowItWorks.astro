---
// HowItWorks — lifted from All Clean (home).
---
        <section class="section_home-hiw">
          <div class="padding-global">
            <div class="w-layout-blockcontainer container-large w-container">
              <div class="w-layout-grid hiw_halves">
                <div
                  id="w-node-dd23bb0f-d679-fca4-7054-c10bb489bafe-d4b7caab"
                  data-w-id="dd23bb0f-d679-fca4-7054-c10bb489bafe"
                  style="opacity:1"
                  class="headline_hiw"
                >
                  <h2 id="hiw-heading" class="margin-0">КАК ЭТО<div>РАБОТАЕТ?</div></h2>
                  <p class="text-size-large">
                    Показываем, как проходит уборка, шаг за шагом — просто, быстро и удобно для вас.
                  </p>
                  <a
                    href="/book-cleaning"
                    button=""
                    data-wf--cta-primary--variant="primary"
                    class="cta_primary w-inline-block"
                    ><div class="button_text-mask">
                      <div button-icon-right="" class="icon-wrap_button">
                        <div class="wrap_icon-btn">
                          <div class="icon_button w-embed">
                            <svg
                              width="100%"
                              height="100%"
                              viewBox="0 0 16 16"
                              fill="none"
                              xmlns="http://www.w3.org/2000/svg"
                            >
                              <path
                                d="M3.33337 8.00016H12.6667M12.6667 8.00016L8.00004 3.3335M12.6667 8.00016L8.00004 12.6668"
                                stroke="currentColor"
                                stroke-width="var(--_❇️-icon---icon-stroke)"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                              />
                            </svg>
                          </div>
                        </div>
                      </div>
                      <div button-text="" class="text-button">
                        Запишитесь на уборку
                      </div>
                    </div>
                    <div button-bg="" class="btn-bg"></div
                  ></a>
                </div>
                <div
                  data-w-id="8280b6c1-1629-db70-cf67-11efb39599c0"
                  style="opacity:1"
                  class="hiw_list"
                >
                  <div class="hiw_item">
                    <div class="number-hiw">
                      <div class="heading-style-h2">01</div>
                    </div>
                    <div class="text-wrap_hiw">
                      <div class="heading-style-h5">Записаться на уборку</div>
                      <div>
                        Выберите дату и время меньше чем за 60 секунд.
                      </div>
                    </div>
                  </div>
                  <div class="hiw_item">
                    <div class="number-hiw">
                      <div class="heading-style-h2">02</div>
                    </div>
                    <div class="text-wrap_hiw">
                      <div class="heading-style-h5">
                        Приезжаем со всем необходимым
                      </div>
                      <div>
                        Клинер привозит весь инвентарь и эко-средства.
                      </div>
                    </div>
                  </div>
                  <div class="hiw_item">
                    <div class="number-hiw">
                      <div class="heading-style-h2">03</div>
                    </div>
                    <div class="text-wrap_hiw">
                      <div class="heading-style-h5">
                        Наслаждайтесь чистым домом
                      </div>
                      <div>
                        Всё убрано и разложено по местам — именно так, как вы хотите.
                      </div>
                    </div>
                  </div>
                  <div class="hiw_item">
                    <div class="number-hiw">
                      <div class="heading-style-h2">04</div>
                    </div>
                    <div class="text-wrap_hiw">
                      <div class="heading-style-h5">Регулярно? Ещё проще</div>
                      <div>Закрепляем за вами одного клинера.</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>
