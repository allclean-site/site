---
// CtaSection — lifted from All Clean (home).
---
      <section class="section_cta">
        <div class="padding-global">
          <div class="w-layout-blockcontainer container-large w-container">
            <div class="master_cta">
              <div class="content_cta">
                <h2 id="cta-heading">ВЫ ГОТОВЫ<div>К ПОЛНОЙ ЧИСТОТЕ?</div></h2>
                <div class="subtext_cta">
                  <p class="text-size-large">
                    Закажите клинеров, которые действительно приезжают, заботятся и оставляют дом идеально чистым.
                  </p>
                </div>
                <div class="button-group_center">
                  <a
                    href="/book-cleaning"
                    button=""
                    data-wf--cta-primary--variant="lift"
                    class="cta_primary w-inline-block"
                    ><div class="button_text-mask">
                      <div button-icon-right="" class="icon-wrap_button">
                        <div class="wrap_icon-btn">
                          <div class="icon_button w-embed">
                            <svg
                              width="100%"
                              height="100%"
                              viewBox="0 0 16 16"
                              fill="none"
                              xmlns="http://www.w3.org/2000/svg"
                            >
                              <path
                                d="M3.33337 8.00016H12.6667M12.6667 8.00016L8.00004 3.3335M12.6667 8.00016L8.00004 12.6668"
                                stroke="currentColor"
                                stroke-width="var(--_❇️-icon---icon-stroke)"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                              />
                            </svg>
                          </div>
                        </div>
                      </div>
                      <div button-text="" class="text-button">
                        Запишитесь на уборку
                      </div>
                    </div>
                    <div
                      button-bg=""
                      class="btn-bg w-variant-f3c49ac3-5f19-afad-90be-3c82d51179b6"
                    ></div></a
                  ><a
                    href="/pricing"
                    button=""
                    data-wf--cta-primary--variant="secondary"
                    class="cta_primary w-variant-1ff8d96e-78cc-eac8-de90-206ecdaded5f w-inline-block"
                    ><div class="button_text-mask">
                      <div button-icon-right="" class="icon-wrap_button">
                        <div class="wrap_icon-btn">
                          <div class="icon_button w-embed">
                            <svg
                              width="100%"
                              height="100%"
                              viewBox="0 0 16 16"
                              fill="none"
                              xmlns="http://www.w3.org/2000/svg"
                            >
                              <path
                                d="M3.33337 8.00016H12.6667M12.6667 8.00016L8.00004 3.3335M12.6667 8.00016L8.00004 12.6668"
                                stroke="currentColor"
                                stroke-width="var(--_❇️-icon---icon-stroke)"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                              />
                            </svg>
                          </div>
                        </div>
                      </div>
                      <div button-text="" class="text-button">Смотреть цены</div>
                    </div>
                    <div
                      button-bg=""
                      class="btn-bg w-variant-1ff8d96e-78cc-eac8-de90-206ecdaded5f"
                    ></div
                  ></a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
