---
// Features — lifted from All Clean (home).
---
        <section class="section_home-features">
          <div class="padding-global">
            <div class="w-layout-blockcontainer container-large w-container">
              <div class="w-layout-grid home-features_halves">
                <div
                  data-w-id="e55037fc-963c-1cb8-ea02-1e859576af2e"
                  style="opacity:1"
                  class="image-wrap_home-features"
                >
                  <img
                    src="https://cdn.prod.website-files.com/692f17afc3743c9cd4b7cac6/69386b748a305c19108b2504_home-about-image.avif"
                    loading="lazy"
                    alt="Two smiling cleaning staff in beige uniforms holding cleaning tools against a plain white wall."
                    class="image_cover vertical"
                  />
                </div>
                <div class="right_home-features">
                  <div
                    data-w-id="ad996a8f-995c-1087-827c-2abe53fda80c"
                    style="opacity:1"
                    class="headline_home-featires"
                  >
