---
import { SUPABASE_URL, SUPABASE_KEY } from '../lib/supabasePublic';
interface Props { calc: any; locale: 'ru' | 'ro'; }
const { calc, locale } = Astro.props;
const cfg = calc.config || {};
const L = locale;
const name = (calc.name && calc.name[L]) || (locale === 'ru' ? 'Калькулятор' : 'Calculator');
const PROJECT_ID = '8878db57-c541-4502-bfa6-ae812dc3aefd';
const fields = cfg.fields || [];

const t = locale === 'ru'
  ? { label: 'Калькулятор', back: 'Назад', next: 'Далее', est: 'Примерная стоимость', estShort: 'Примерно',
      comments: 'Комментарий (что нам важно знать)', commentsPh: 'Например: сильное загрязнение, есть животные, нужен определённый день…',
      photos: 'Фото помещения (по желанию)', photosHint: 'Помогут точнее оценить. До 6 фото.', addPhoto: 'Добавить фото', details: 'Комментарий и фото',
      name: 'Ваше имя', phone: 'Телефон', submit: 'Отправить заявку', lift: 'Лифт', liftYes: 'Есть', liftNo: 'Нет',
      note: 'Это предварительная оценка. Точную цену подтвердит менеджер.', ok: 'Заявка отправлена! Менеджер свяжется с вами.',
      err: 'Не удалось отправить. Позвоните: +373 79 955 044', need: 'Заполните имя и телефон.', from: 'от',
      s_type: 'Тип уборки', s_area: 'Площадь', s_floor: 'Этаж и лифт', s_win: 'Окна', s_extra: 'Дополнительно' }
  : { label: 'Calculator', back: 'Înapoi', next: 'Înainte', est: 'Cost aproximativ', estShort: 'Aproximativ',
      comments: 'Comentariu (ce e important să știm)', commentsPh: 'De exemplu: murdărie puternică, animale, o anumită zi…',
      photos: 'Fotografii (opțional)', photosHint: 'Ajută la o estimare mai exactă. Până la 6 foto.', addPhoto: 'Adaugă foto', details: 'Comentariu și foto',
      name: 'Numele dvs.', phone: 'Telefon', submit: 'Trimite cererea', lift: 'Lift', liftYes: 'Da', liftNo: 'Nu',
      note: 'Aceasta este o estimare. Prețul exact va fi confirmat de manager.', ok: 'Cererea a fost trimisă! Managerul vă va contacta.',
      err: 'Nu s-a putut trimite. Sunați: +373 79 955 044', need: 'Completați numele și telefonul.', from: 'de la',
      s_type: 'Tipul curățeniei', s_area: 'Suprafața', s_floor: 'Etaj și lift', s_win: 'Geamuri', s_extra: 'Suplimentar' };

const used = new Set<string>();
const steps: any[] = [];
const typeFields = fields.filter((f: any) => f.affects === 'rate');
if (typeFields.length) { steps.push({ title: t.s_type, fields: typeFields, cards: true }); typeFields.forEach((f: any) => used.add(f.key)); }
const areaF = fields.find((f: any) => f.type === 'number' && f.perUnitFrom === 'rate');
if (areaF) { steps.push({ title: t.s_area, fields: [areaF] }); used.add(areaF.key); }
const floorF = fields.find((f: any) => f.key === 'floor');
if (floorF) { steps.push({ title: t.s_floor, fields: [floorF], lift: true }); used.add('floor'); }
const winFields = fields.filter((f: any) => f.key.indexOf('win') === 0 && !used.has(f.key));
if (winFields.length) { steps.push({ title: t.s_win, fields: winFields }); winFields.forEach((f: any) => used.add(f.key)); }
const rest = fields.filter((f: any) => !used.has(f.key));
if (rest.length) steps.push({ title: t.s_extra, fields: rest });
const detailsStep = steps.length;       // comments + photos
const totalSteps = steps.length + 1;
const icons = ['🧽', '🛠️', '✨', '🧹', '🪣'];
---
<main class="main-wrapper">
  <section class="section_hero-faq">
    <div class="padding-global">
      <div class="w-layout-blockcontainer container-large w-container">
        <div class="calc-head">
          <div data-wf--tag--variant="depth" class="master_label w-variant-9a59c277-b838-5a8e-f25e-39f9204dca4d"><div class="label-large">{t.label}</div></div>
          <h1>{name}</h1>
        </div>

        <div class="calc-layout">
          <!-- LEFT: the quiz container -->
          <div class="calc-wizard" id="calc">
            <div class="calc-top">
              <div class="calc-stepno"><span id="calc-stepno">1</span> / {totalSteps}</div>
              <div class="calc-progress"><div class="calc-progress-bar" id="calc-bar"></div></div>
            </div>

            <div class="calc-body">
              {steps.map((s: any, si: number) => (
                <div class="calc-step" data-step={si} style={si === 0 ? '' : 'display:none'}>
                  <h3 class="calc-step-title">{s.title}</h3>
                  {s.fields.map((f: any) => (
                    <div class="calc-field" data-key={f.key} data-type={f.type}>
                      {!s.cards && <div class="calc-q">{f.label?.[L] || f.key}</div>}
                      {f.type === 'select' && s.cards && (
                        <div class="calc-cards">
                          {(f.options || []).map((o: any, i: number) => (
                            <button type="button" class={'calc-card' + (i === 0 ? ' on' : '')} data-val={o.value}>
                              <span class="calc-card-ico">{o.img ? <img src={o.img} alt="" /> : icons[i % icons.length]}</span>
                              <span class="calc-card-label">{o.label?.[L] || o.value}</span>
                              <span class="calc-card-check" aria-hidden>✓</span>
                            </button>
                          ))}
                        </div>
                      )}
                      {f.type === 'select' && !s.cards && (
                        <div class="calc-opts">
                          {(f.options || []).map((o: any, i: number) => (
                            <button type="button" class={'calc-opt' + (i === 0 ? ' on' : '')} data-val={o.value}>
                              <span>{o.label?.[L] || o.value}</span>{o.badge && <em class="calc-badge">{o.badge}</em>}
                            </button>
                          ))}
                        </div>
                      )}
                      {f.type === 'number' && (
                        <div class="calc-num">
                          <input type="range" min={f.min ?? 0} max={f.max ?? 100} step={f.step ?? 1} value={f.default ?? f.min ?? 0} class="calc-range" />
                          <output class="calc-val">{f.default ?? f.min ?? 0}</output>
                        </div>
                      )}
                      {f.type === 'multi' && (
                        <div class="calc-opts">
                          {(f.options || []).map((o: any) => (
                            <button type="button" class="calc-opt calc-multi" data-val={o.value}><span>{o.label?.[L] || o.value}</span></button>
                          ))}
                        </div>
                      )}
                    </div>
                  ))}
                  {s.lift && (
                    <div class="calc-field" data-key="lift" data-type="liftbtns">
                      <div class="calc-q">{t.lift}</div>
                      <div class="calc-opts">
                        <button type="button" class="calc-opt calc-lift on" data-val="yes"><span>{t.liftYes}</span></button>
                        <button type="button" class="calc-opt calc-lift" data-val="no"><span>{t.liftNo}</span></button>
                      </div>
                    </div>
                  )}
                </div>
              ))}

              <!-- last quiz step: comments + photos -->
              <div class="calc-step" data-step={detailsStep} style="display:none">
                <h3 class="calc-step-title">{t.details}</h3>
                <label class="calc-q calc-lbl">{t.comments}
                  <textarea id="calc-comment" class="calc-input calc-area" placeholder={t.commentsPh}></textarea>
                </label>
                <div class="calc-q calc-lbl">{t.photos} <span class="calc-hint">{t.photosHint}</span>
                  <div class="calc-photos" id="calc-photos"></div>
                  <button type="button" class="calc-add-photo" id="calc-add-photo">＋ {t.addPhoto}</button>
                  <input type="file" id="calc-file" accept="image/*" multiple hidden />
                </div>
              </div>
            </div>

            <div class="calc-nav">
              <button type="button" class="calc-back" id="calc-back" style="visibility:hidden">← {t.back}</button>
              <button type="button" class="calc-next" id="calc-next">{t.next} →</button>
            </div>
          </div>

          <!-- RIGHT: persistent estimate + contact form (1/3) -->
          <aside class="calc-side">
            <div class="calc-side-card">
              <div class="calc-side-label">{t.est}</div>
              <div class="calc-side-price"><span id="calc-price">0</span> <span class="calc-cur">MDL</span></div>
              <p class="calc-side-note">{t.note}</p>
              <input id="calc-name" class="calc-input" placeholder={t.name} />
              <input id="calc-phone" class="calc-input" placeholder={t.phone} inputmode="tel" />
              <button type="button" id="calc-submit" class="calc-cta">{t.submit}</button>
              <p id="calc-msg" class="calc-msg"></p>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </section>
</main>

<script type="application/json" id="calc-cfg" set:html={JSON.stringify(cfg)} is:inline />
<script define:vars={{ SUPABASE_URL, SUPABASE_KEY, PROJECT_ID, locale, slug: calc.slug, t, totalSteps }}>
  (function () {
    var cfg = JSON.parse(document.getElementById('calc-cfg').textContent);
    var root = document.getElementById('calc');
    var state = {}, lift = 'yes', photos = [], step = 0;
    cfg.fields.forEach(function (f) {
      if (f.type === 'select') state[f.key] = (f.options && f.options[0] && f.options[0].value) || null;
      else if (f.type === 'number') state[f.key] = f.default != null ? f.default : (f.min || 0);
      else if (f.type === 'multi') state[f.key] = [];
    });

    function compute() {
      var total = cfg.base || 0, mult = 1, rates = {};
      cfg.fields.forEach(function (f) { if (f.type === 'select' && f.affects) { var o = (f.options || []).find(function (x) { return x.value === state[f.key]; }); if (o && o.rate != null) rates[f.affects] = o.rate; } });
      cfg.fields.forEach(function (f) {
        if (f.type === 'select') { var o = (f.options || []).find(function (x) { return x.value === state[f.key]; }); if (!o) return; if (o.add) total += o.add; if (o.mult != null) mult *= o.mult; }
        else if (f.type === 'number') { var per = f.perUnit != null ? f.perUnit : (f.perUnitFrom ? (rates[f.perUnitFrom] || 0) : 0); var c = (Number(state[f.key]) || 0) * per; if (f.doubleIf && (f.doubleIf.in || []).indexOf(state[f.doubleIf.field]) >= 0) c *= 2; total += c; }
        else if (f.type === 'multi') { (state[f.key] || []).forEach(function (v) { var o = (f.options || []).find(function (x) { return x.value === v; }); if (o && o.add) total += o.add; }); }
      });
      total *= mult; if (cfg.minPrice) total = Math.max(total, cfg.minPrice);
      return Math.max(0, Math.round(total / 10) * 10);
    }
    function fmt(n) { return n.toLocaleString('ru-RU'); }
    function priceText() { var low = compute(); if (cfg.showRange) { var high = Math.round(low * (cfg.rangeUpRatio || 1.25) / 10) * 10; return t.from + ' ' + fmt(low) + '–' + fmt(high); } return fmt(low); }
    function render() { document.getElementById('calc-price').textContent = priceText(); }

    root.querySelectorAll('.calc-field').forEach(function (fl) {
      var key = fl.dataset.key, type = fl.dataset.type;
      if (type === 'select') { fl.querySelectorAll('.calc-card,.calc-opt').forEach(function (b) { b.addEventListener('click', function () { fl.querySelectorAll('.calc-card,.calc-opt').forEach(function (x) { x.classList.remove('on'); }); b.classList.add('on'); state[key] = b.dataset.val; render(); }); }); }
      else if (type === 'multi') { fl.querySelectorAll('.calc-opt').forEach(function (b) { b.addEventListener('click', function () { b.classList.toggle('on'); state[key] = [].slice.call(fl.querySelectorAll('.calc-opt.on')).map(function (x) { return x.dataset.val; }); render(); }); }); }
      else if (type === 'liftbtns') { fl.querySelectorAll('.calc-lift').forEach(function (b) { b.addEventListener('click', function () { fl.querySelectorAll('.calc-lift').forEach(function (x) { x.classList.remove('on'); }); b.classList.add('on'); lift = b.dataset.val; }); }); }
      else if (type === 'number') { var rng = fl.querySelector('.calc-range'), out = fl.querySelector('.calc-val'); rng.addEventListener('input', function () { state[key] = Number(rng.value); out.textContent = rng.value; render(); }); }
    });

    function showStep(n) {
      step = Math.max(0, Math.min(totalSteps - 1, n));
      root.querySelectorAll('.calc-step').forEach(function (el) { el.style.display = Number(el.dataset.step) === step ? '' : 'none'; });
      document.getElementById('calc-stepno').textContent = step + 1;
      document.getElementById('calc-bar').style.width = ((step + 1) / totalSteps * 100) + '%';
      document.getElementById('calc-back').style.visibility = step === 0 ? 'hidden' : 'visible';
      document.getElementById('calc-next').style.display = step === totalSteps - 1 ? 'none' : '';
      root.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
    }
    document.getElementById('calc-next').addEventListener('click', function () { showStep(step + 1); });
    document.getElementById('calc-back').addEventListener('click', function () { showStep(step - 1); });

    var fileInput = document.getElementById('calc-file'), photosBox = document.getElementById('calc-photos');
    document.getElementById('calc-add-photo').addEventListener('click', function () { if (photos.length >= 6) return; fileInput.click(); });
    fileInput.addEventListener('change', function () {
      [].slice.call(fileInput.files).forEach(function (f) {
        if (photos.length >= 6 || !/^image\//.test(f.type)) return;
        var ph = document.createElement('div'); ph.className = 'calc-photo'; ph.innerHTML = '<span class="calc-photo-load">…</span>'; photosBox.appendChild(ph);
        var path = 'apartments/' + Date.now() + '-' + Math.random().toString(36).slice(2, 7) + '.' + (f.name.split('.').pop() || 'jpg').toLowerCase();
        fetch(SUPABASE_URL + '/storage/v1/object/calc-uploads/' + path, { method: 'POST', headers: { apikey: SUPABASE_KEY, Authorization: 'Bearer ' + SUPABASE_KEY, 'content-type': f.type, 'x-upsert': 'true' }, body: f })
          .then(function (r) { if (!r.ok) throw 0; var url = SUPABASE_URL + '/storage/v1/object/public/calc-uploads/' + path; photos.push(url); ph.innerHTML = '<img src="' + url + '" alt=""/><button type="button" class="calc-photo-x">✕</button>'; ph.querySelector('.calc-photo-x').addEventListener('click', function () { photos = photos.filter(function (u) { return u !== url; }); ph.remove(); }); })
          .catch(function () { ph.remove(); });
      });
      fileInput.value = '';
    });

    document.getElementById('calc-submit').addEventListener('click', function () {
      var nm = document.getElementById('calc-name').value.trim(), pho = document.getElementById('calc-phone').value.trim(), msg = document.getElementById('calc-msg');
      if (!nm || !pho) { msg.textContent = t.need; msg.className = 'calc-msg err'; return; }
      msg.textContent = '…'; msg.className = 'calc-msg';
      var sel = {};
      cfg.fields.forEach(function (f) { var v = state[f.key];
        if (f.type === 'multi') sel[f.label[locale] || f.key] = (v || []).map(function (val) { var o = f.options.find(function (x) { return x.value === val; }); return o ? (o.label[locale] || val) : val; });
        else if (f.type === 'select') { var o = (f.options || []).find(function (x) { return x.value === v; }); sel[f.label[locale] || f.key] = o ? (o.label[locale] || v) : v; }
        else sel[f.label[locale] || f.key] = v; });
      sel[t.lift] = lift === 'yes' ? t.liftYes : t.liftNo;
      var cm = document.getElementById('calc-comment'); var comment = cm ? cm.value.trim() : '';
      fetch(SUPABASE_URL + '/rest/v1/site_leads', {
        method: 'POST', headers: { apikey: SUPABASE_KEY, Authorization: 'Bearer ' + SUPABASE_KEY, 'Content-Type': 'application/json', Prefer: 'return=minimal' },
        body: JSON.stringify({ project_id: PROJECT_ID, name: nm, phone: pho, service: 'Калькулятор: ' + slug, notes: JSON.stringify({ selections: sel, estimate: compute() + ' MDL', comment: comment, photos: photos }), locale: locale, source_url: location.href }),
      }).then(function (r) { if (r.ok) { msg.textContent = t.ok; msg.className = 'calc-msg ok'; } else { msg.textContent = t.err; msg.className = 'calc-msg err'; } })
        .catch(function () { msg.textContent = t.err; msg.className = 'calc-msg err'; });
    });

    render(); showStep(0);
  })();
</script>

<style>
  .calc-head { text-align: center; margin: 0 auto 30px; }
  .calc-head h1 { color: #0c2959; margin-top: 12px; }
  .calc-layout { display: grid; grid-template-columns: 2fr 1fr; gap: 24px; align-items: start; max-width: 1040px; margin: 0 auto; }
  /* LEFT — quiz block */
  .calc-wizard { background: #fff; border: 1px solid #dbe6fb; border-radius: 22px; box-shadow: 0 24px 60px rgba(12, 41, 89, .10); overflow: hidden; display: flex; flex-direction: column; }
  .calc-top { padding: 18px 24px 0; }
  .calc-stepno { color: #8a99b5; font-size: .85rem; font-weight: 700; margin-bottom: 8px; }
  .calc-progress { height: 6px; background: #eef3fd; border-radius: 999px; overflow: hidden; }
  .calc-progress-bar { height: 100%; width: 20%; background: linear-gradient(90deg, #2b6cf6, #7c3aed); border-radius: 999px; transition: width .35s ease; }
  .calc-body { padding: 24px; min-height: 300px; }
  .calc-step-title { color: #0c2959; font-size: 1.35rem; margin: 0 0 20px; }
  .calc-field { margin-bottom: 22px; }
  .calc-q { color: #0c2959; font-weight: 700; font-size: 1.02rem; margin-bottom: 12px; display: block; }
  .calc-hint { color: #8a99b5; font-weight: 400; font-size: .85rem; }
  .calc-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 14px; }
  .calc-card { position: relative; display: flex; flex-direction: column; align-items: center; gap: 10px; padding: 22px 14px; border: 2px solid #e6ecf7; border-radius: 16px; background: #fff; cursor: pointer; transition: .15s; text-align: center; }
  .calc-card:hover { border-color: #b6cbf9; } .calc-card.on { border-color: #2b6cf6; background: #f4f8ff; }
  .calc-card-ico { font-size: 2rem; width: 56px; height: 56px; display: flex; align-items: center; justify-content: center; background: #eef3fd; border-radius: 14px; }
  .calc-card-ico img { width: 100%; height: 100%; object-fit: cover; border-radius: 14px; }
  .calc-card-label { color: #1c2b47; font-weight: 700; font-size: .98rem; line-height: 1.25; }
  .calc-card-check { position: absolute; top: 10px; right: 10px; width: 22px; height: 22px; border-radius: 50%; background: #2b6cf6; color: #fff; font-size: .8rem; display: flex; align-items: center; justify-content: center; opacity: 0; transform: scale(.6); transition: .15s; }
  .calc-card.on .calc-card-check { opacity: 1; transform: scale(1); }
  .calc-opts { display: flex; flex-wrap: wrap; gap: 10px; }
  .calc-opt { display: inline-flex; align-items: center; gap: 8px; padding: 11px 16px; border: 1px solid #dbe6fb; border-radius: 12px; background: #fff; color: #1c2b47; font-weight: 600; cursor: pointer; transition: .15s; font-size: .95rem; }
  .calc-opt:hover { border-color: #b6cbf9; } .calc-opt.on { background: #0c2959; color: #fff; border-color: #0c2959; }
  .calc-badge { font-style: normal; font-size: .8rem; background: #b6cbf9; color: #0c2959; border-radius: 999px; padding: 1px 8px; font-weight: 700; } .calc-opt.on .calc-badge { background: #fff; }
  .calc-num { display: flex; align-items: center; gap: 16px; }
  .calc-range { flex: 1; accent-color: #2b6cf6; height: 6px; }
  .calc-val { min-width: 70px; text-align: center; font-weight: 800; color: #0c2959; font-size: 1.2rem; background: #eef3fd; border-radius: 10px; padding: 6px 10px; }
  .calc-lbl { display: block; }
  .calc-area { min-height: 90px; resize: vertical; margin-top: 8px; }
  .calc-photos { display: flex; flex-wrap: wrap; gap: 10px; margin: 10px 0; }
  .calc-photo { position: relative; width: 84px; height: 84px; border-radius: 12px; overflow: hidden; background: #eef3fd; display: flex; align-items: center; justify-content: center; }
  .calc-photo img { width: 100%; height: 100%; object-fit: cover; }
  .calc-photo-x { position: absolute; top: 3px; right: 3px; width: 20px; height: 20px; border: 0; border-radius: 50%; background: rgba(12, 41, 89, .8); color: #fff; cursor: pointer; font-size: .7rem; }
  .calc-add-photo { padding: 10px 16px; border: 1px dashed #b6cbf9; border-radius: 12px; background: #f4f8ff; color: #2b6cf6; font-weight: 700; cursor: pointer; }
  .calc-nav { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 16px 24px; border-top: 1px solid #eef3fd; background: #fbfcff; }
  .calc-back, .calc-next { padding: 11px 20px; border-radius: 12px; font-weight: 800; cursor: pointer; border: 0; }
  .calc-back { background: #eef3fd; color: #0c2959; } .calc-next { background: #0c2959; color: #fff; }
  /* RIGHT — estimate + contacts (1/3) */
  .calc-side-card { position: sticky; top: 100px; background: #0c2959; color: #fff; border-radius: 20px; padding: 26px; box-shadow: 0 24px 60px rgba(12, 41, 89, .25); display: flex; flex-direction: column; gap: 12px; }
  .calc-side-label { opacity: .8; font-size: .95rem; }
  .calc-side-price { font-size: clamp(1.8rem, 4vw, 2.4rem); font-weight: 800; line-height: 1.05; margin-top: -4px; }
  .calc-cur { font-size: 1.1rem; opacity: .85; }
  .calc-side-note { font-size: .85rem; opacity: .8; line-height: 1.5; margin: 0 0 4px; }
  .calc-input { width: 100%; padding: 12px 14px; border-radius: 12px; border: 1px solid rgba(255, 255, 255, .25); background: rgba(255, 255, 255, .1); color: #fff; font-size: 1rem; }
  .calc-input::placeholder { color: rgba(255, 255, 255, .6); }
  .calc-side .calc-input { }
  .calc-area { color: #1c2b47; background: #fff; border-color: #dbe6fb; }  /* comment textarea lives on the white left side */
  .calc-cta { width: 100%; padding: 15px; border: 0; border-radius: 14px; background: #b6cbf9; color: #0c2959; font-weight: 800; cursor: pointer; font-size: 1.02rem; }
  .calc-cta:hover { filter: brightness(1.06); }
  .calc-msg { font-size: .9rem; margin: 2px 0 0; min-height: 1.2em; } .calc-msg.ok { color: #86efac; } .calc-msg.err { color: #fca5a5; }
  @media (max-width: 860px) {
    .calc-layout { grid-template-columns: 1fr; }
    .calc-side-card { position: static; }
  }
  @media (max-width: 560px) {
    .calc-body { padding: 18px; min-height: 240px; }
    .calc-cards { grid-template-columns: 1fr 1fr; }
    .calc-nav { padding: 12px 16px; } .calc-back, .calc-next { flex: 1; }
  }
</style>
