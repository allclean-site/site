---
import { SUPABASE_URL, SUPABASE_KEY } from '../lib/supabasePublic';
interface Props { calc: any; locale: 'ru' | 'ro'; embedded?: boolean; uid?: string; hidden?: boolean; }
const { calc, locale, embedded = false, uid = 'calc', hidden = false } = Astro.props;
const cfg = calc.config || {};
const L = locale;
const name = (calc.name && calc.name[L]) || (locale === 'ru' ? 'Калькулятор' : 'Calculator');
const PROJECT_ID = '8878db57-c541-4502-bfa6-ae812dc3aefd';
const fields = cfg.fields || [];

const t = locale === 'ru'
  ? { back: 'Назад', next: 'Далее', est: 'Примерная стоимость', done: 'Готово',
      comments: 'Комментарий (что нам важно знать)', commentsPh: 'Например: сильное загрязнение, есть животные, нужен определённый день…',
      photos: 'Фото помещения (по желанию)', photosHint: 'Помогут точнее оценить. До 6 фото.', addPhoto: 'Добавить фото', details: 'Комментарий и фото',
      name: 'Ваше имя', phone: 'Телефон', submit: 'Отправить заявку', lift: 'Лифт', liftYes: 'Есть', liftNo: 'Нет', choose: 'Выберите параметры',
      note: 'Это предварительная оценка. Точную цену подтвердит менеджер.', ok: 'Заявка отправлена! Менеджер свяжется с вами.',
      err: 'Не удалось отправить. Позвоните: +373 79 955 044', need: 'Заполните имя и телефон.', from: 'от',
      consent: 'Я согласен(-на) на обработку персональных данных согласно', privacy: 'политике конфиденциальности', privacyUrl: '/privacy',
      consentNeed: 'Подтвердите согласие на обработку данных.', phoneBad: 'Введите корректный номер: +373 XX XXX XXX.',
      s_type: 'Тип уборки', s_area: 'Площадь', s_floor: 'Этаж и лифт', s_win: 'Окна', s_extra: 'Дополнительные услуги', tap: 'нажмите, чтобы выбрать' }
  : { back: 'Înapoi', next: 'Înainte', est: 'Cost aproximativ', done: 'Gata',
      comments: 'Comentariu (ce e important să știm)', commentsPh: 'De exemplu: murdărie puternică, animale, o anumită zi…',
      photos: 'Fotografii (opțional)', photosHint: 'Ajută la o estimare mai exactă. Până la 6 foto.', addPhoto: 'Adaugă foto', details: 'Comentariu și foto',
      name: 'Numele dvs.', phone: 'Telefon', submit: 'Trimite cererea', lift: 'Lift', liftYes: 'Da', liftNo: 'Nu', choose: 'Alegeți parametrii',
      note: 'Aceasta este o estimare. Prețul exact va fi confirmat de manager.', ok: 'Cererea a fost trimisă! Managerul vă va contacta.',
      err: 'Nu s-a putut trimite. Sunați: +373 79 955 044', need: 'Completați numele și telefonul.', from: 'de la',
      consent: 'Sunt de acord cu prelucrarea datelor cu caracter personal conform', privacy: 'politicii de confidențialitate', privacyUrl: '/ro/privacy',
      consentNeed: 'Confirmați acordul privind prelucrarea datelor.', phoneBad: 'Introduceți un număr valid: +373 XX XXX XXX.',
      s_type: 'Tipul curățeniei', s_area: 'Suprafața', s_floor: 'Etaj și lift', s_win: 'Geamuri', s_extra: 'Servicii suplimentare', tap: 'apăsați pentru a alege' };

const used = new Set<string>();
const steps: any[] = [];
const typeFields = fields.filter((f: any) => f.affects === 'rate');
if (typeFields.length) { steps.push({ title: t.s_type, fields: typeFields, cards: true }); typeFields.forEach((f: any) => used.add(f.key)); }
const areaF = fields.find((f: any) => f.type === 'number' && f.perUnitFrom === 'rate');
if (areaF) { steps.push({ title: t.s_area, fields: [areaF] }); used.add(areaF.key); }
const floorF = fields.find((f: any) => f.key === 'floor');
if (floorF) { steps.push({ title: t.s_floor, fields: [floorF], lift: true }); used.add('floor'); }
const winFields = fields.filter((f: any) => f.key.indexOf('win') === 0 && !used.has(f.key));
if (winFields.length) { steps.push({ title: t.s_win, fields: winFields }); winFields.forEach((f: any) => used.add(f.key)); }
const rest = fields.filter((f: any) => !used.has(f.key));
if (rest.length) steps.push({ title: t.s_extra, fields: rest, tiles: true });
const detailsStep = steps.length;
const totalSteps = steps.length + 1;
const icons = ['🧽', '🛠️', '✨', '🧹', '🪣'];
const tileIco: Record<string, string> = { surfaces: '🧴', kitchen: '🍳', bath: '🚿', ironing: '👔', curtains: '🪟', dishes: '🍽️', ac: '❄️' };
---
<section class={embedded ? 'section_faq calc-embedded' : 'section_hero-faq'} id={embedded ? (uid + '-section') : undefined}>
    <div class="padding-global">
      <div class="w-layout-blockcontainer container-large w-container">
        <div class="calc-head">{embedded ? <h2>{name}</h2> : <h1>{name}</h1>}</div>

        <div class="calc-layout">
          <!-- LEFT: quiz container -->
          <div class="calc-wizard" id={uid}>
            <div class="calc-top">
              <div class="calc-stepno"><span id={uid + '-stepno'}>1</span> / {totalSteps}</div>
              <div class="calc-progress"><div class="calc-progress-bar" id={uid + '-bar'}></div></div>
            </div>

            <div class="calc-body">
              {steps.map((s: any, si: number) => (
                <div class="calc-step" data-step={si} style={si === 0 ? '' : 'display:none'}>
                  <h3 class="calc-step-title">{s.title}</h3>

                  {s.tiles ? (
                    <div class="calc-tiles">
                      {s.fields.map((f: any) => (
                        <button type="button" class="calc-tile" data-key={f.key}>
                          <span class="calc-tile-ico">{tileIco[f.key] || '✨'}</span>
                          <span class="calc-tile-name">{f.label?.[L] || f.key}</span>
                          <span class="calc-tile-sel" data-tap={t.tap}></span>
                          <span class="calc-tile-check" aria-hidden>✓</span>
                        </button>
                      ))}
                    </div>
                  ) : (
                    s.fields.map((f: any) => (
                      <div class="calc-field" data-key={f.key} data-type={f.type}>
                        {!s.cards && <div class="calc-q">{f.label?.[L] || f.key}</div>}
                        {f.type === 'select' && s.cards && (
                          <div class="calc-cards">
                            {(f.options || []).map((o: any, i: number) => (
                              <button type="button" class={'calc-card' + (i === 0 ? ' on' : '')} data-val={o.value}>
                                <span class="calc-card-ico">{o.img ? <img src={o.img} alt="" /> : icons[i % icons.length]}</span>
                                <span class="calc-card-label">{o.label?.[L] || o.value}</span>
                                <span class="calc-card-check" aria-hidden>✓</span>
                              </button>
                            ))}
                          </div>
                        )}
                        {f.type === 'select' && !s.cards && (
                          <div class="calc-opts">
                            {(f.options || []).map((o: any, i: number) => (
                              <button type="button" class={'calc-opt' + (i === 0 ? ' on' : '')} data-val={o.value}>
                                <span>{o.label?.[L] || o.value}</span>{o.badge && <em class="calc-badge">{o.badge}</em>}
                              </button>
                            ))}
                          </div>
                        )}
                        {f.type === 'number' && (
                          <div class="calc-num">
                            <input type="range" min={f.min ?? 0} max={f.max ?? 100} step={f.step ?? 1} value={f.default ?? f.min ?? 0} class="calc-range" />
                            <output class="calc-val">{f.default ?? f.min ?? 0}</output>
                          </div>
                        )}
                        {f.type === 'multi' && (
                          <div class="calc-opts">
                            {(f.options || []).map((o: any) => (
                              <button type="button" class="calc-opt calc-multi" data-val={o.value}><span>{o.label?.[L] || o.value}</span></button>
                            ))}
                          </div>
                        )}
                      </div>
                    ))
                  )}

                  {s.lift && (
                    <div class="calc-field" data-key="lift" data-type="liftbtns">
                      <div class="calc-q">{t.lift}</div>
                      <div class="calc-opts">
                        <button type="button" class="calc-opt calc-lift on" data-val="yes"><span>{t.liftYes}</span></button>
                        <button type="button" class="calc-opt calc-lift" data-val="no"><span>{t.liftNo}</span></button>
                      </div>
                    </div>
                  )}
                </div>
              ))}

              <div class="calc-step" data-step={detailsStep} style="display:none">
                <h3 class="calc-step-title">{t.details}</h3>
                <label class="calc-q calc-lbl">{t.comments}
                  <textarea id={uid + '-comment'} class="calc-input calc-area" placeholder={t.commentsPh}></textarea>
                </label>
                <div class="calc-q calc-lbl">{t.photos} <span class="calc-hint">{t.photosHint}</span>
                  <div class="calc-photos" id={uid + '-photos'}></div>
                  <button type="button" class="calc-add-photo" id={uid + '-add-photo'}>＋ {t.addPhoto}</button>
                  <input type="file" id={uid + '-file'} accept="image/*" multiple hidden />
                </div>
              </div>
            </div>

            <div class="calc-nav">
              <button type="button" class="calc-back" id={uid + '-back'} style="visibility:hidden">← {t.back}</button>
              <button type="button" class="calc-next" id={uid + '-next'}>{t.next} →</button>
            </div>

            <!-- parameter popup for extra services -->
            <div class="calc-modal" id={uid + '-modal'} hidden>
              <div class="calc-modal-card">
                <div class="calc-modal-title"></div>
                <div class="calc-modal-opts"></div>
                <button type="button" class="calc-modal-done">{t.done}</button>
              </div>
            </div>
          </div>

          <!-- RIGHT: estimate + contact form -->
          <aside class="calc-side">
            <div class="calc-side-card">
              <div class="calc-side-label">{t.est}</div>
              <div class="calc-side-price"><span id={uid + '-price'}>0</span> <span class="calc-cur">MDL</span></div>
              <p class="calc-side-note">{t.note}</p>
              <div class="calc-side-form">
                <input id={uid + '-name'} class="calc-input" placeholder={t.name} />
                <input id={uid + '-phone'} class="calc-input" placeholder="+373 XX XXX XXX" inputmode="tel" />
                <label class="calc-consent"><input type="checkbox" id={uid + '-consent'} /><span>{t.consent} <a href={t.privacyUrl} target="_blank" rel="noopener">{t.privacy}</a></span></label>
                <button type="button" id={uid + '-submit'} class="calc-cta">{t.submit}</button>
                <p id={uid + '-msg'} class="calc-msg"></p>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </section>

<script type="application/json" id={uid + '-cfg'} set:html={JSON.stringify(cfg)} is:inline />
<script define:vars={{ SUPABASE_URL, SUPABASE_KEY, PROJECT_ID, locale, slug: calc.slug, t, totalSteps, uid }}>
  (function () {
    var cfg = JSON.parse(document.getElementById(uid + '-cfg').textContent);
    var root = document.getElementById(uid);
    var state = {}, lift = 'yes', photos = [], step = 0;
    cfg.fields.forEach(function (f) {
      if (f.type === 'select') state[f.key] = (f.options && f.options[0] && f.options[0].value) || null;
      else if (f.type === 'number') state[f.key] = f.default != null ? f.default : (f.min || 0);
      else if (f.type === 'multi') state[f.key] = [];
    });
    function fieldByKey(k) { return cfg.fields.find(function (f) { return f.key === k; }); }

    function compute() {
      var total = cfg.base || 0, mult = 1, rates = {};
      cfg.fields.forEach(function (f) { if (f.type === 'select' && f.affects) { var o = (f.options || []).find(function (x) { return x.value === state[f.key]; }); if (o && o.rate != null) rates[f.affects] = o.rate; } });
      cfg.fields.forEach(function (f) {
        if (f.type === 'select') { var o = (f.options || []).find(function (x) { return x.value === state[f.key]; }); if (!o) return; if (o.add) total += o.add; if (o.mult != null) mult *= o.mult; }
        else if (f.type === 'number') { var per = f.perUnit != null ? f.perUnit : (f.perUnitFrom ? (rates[f.perUnitFrom] || 0) : 0); var c = (Number(state[f.key]) || 0) * per; if (f.doubleIf && (f.doubleIf.in || []).indexOf(state[f.doubleIf.field]) >= 0) c *= 2; total += c; }
        else if (f.type === 'multi') { (state[f.key] || []).forEach(function (v) { var o = (f.options || []).find(function (x) { return x.value === v; }); if (o && o.add) total += o.add; }); }
      });
      total *= mult; if (cfg.minPrice) total = Math.max(total, cfg.minPrice);
      return Math.max(0, Math.round(total / 10) * 10);
    }
    function fmt(n) { return n.toLocaleString('ru-RU'); }
    function priceText() { var low = compute(); if (cfg.showRange) { var high = Math.round(low * (cfg.rangeUpRatio || 1.25) / 10) * 10; return t.from + ' ' + fmt(low) + '–' + fmt(high); } return fmt(low); }
    function render() { document.getElementById(uid + '-price').textContent = priceText(); }

    // standard fields (type cards, area, floor, windows, lift)
    root.querySelectorAll('.calc-field').forEach(function (fl) {
      var key = fl.dataset.key, type = fl.dataset.type;
      if (type === 'select') { fl.querySelectorAll('.calc-card,.calc-opt').forEach(function (b) { b.addEventListener('click', function () { fl.querySelectorAll('.calc-card,.calc-opt').forEach(function (x) { x.classList.remove('on'); }); b.classList.add('on'); state[key] = b.dataset.val; render(); }); }); }
      else if (type === 'multi') { fl.querySelectorAll('.calc-opt').forEach(function (b) { b.addEventListener('click', function () { b.classList.toggle('on'); state[key] = [].slice.call(fl.querySelectorAll('.calc-opt.on')).map(function (x) { return x.dataset.val; }); render(); }); }); }
      else if (type === 'liftbtns') { fl.querySelectorAll('.calc-lift').forEach(function (b) { b.addEventListener('click', function () { fl.querySelectorAll('.calc-lift').forEach(function (x) { x.classList.remove('on'); }); b.classList.add('on'); lift = b.dataset.val; }); }); }
      else if (type === 'number') { var rng = fl.querySelector('.calc-range'), out = fl.querySelector('.calc-val'); rng.addEventListener('input', function () { state[key] = Number(rng.value); out.textContent = rng.value; render(); }); }
    });

    // extra-service tiles + parameter popup
    var modal = document.getElementById(uid + '-modal');
    function closeModal() { modal.setAttribute('hidden', ''); }
    function updateTile(key) {
      var f = fieldByKey(key); var tile = root.querySelector('.calc-tile[data-key="' + key + '"]'); if (!f || !tile) return;
      var active = false, summary = '';
      if (f.type === 'multi') { var arr = state[key] || []; active = arr.length > 0; summary = arr.map(function (v) { var o = f.options.find(function (x) { return x.value === v; }); return o ? (o.label[locale] || v) : v; }).join(', '); }
      else { var o = (f.options || []).find(function (x) { return x.value === state[key]; }); active = !!(o && o.add); summary = active ? (o.label[locale] || '') : ''; }
      tile.classList.toggle('on', active); tile.querySelector('.calc-tile-sel').textContent = summary;
    }
    function openModal(key) {
      var f = fieldByKey(key); if (!f) return;
      modal.querySelector('.calc-modal-title').textContent = f.label[locale] || key;
      var box = modal.querySelector('.calc-modal-opts'); box.innerHTML = '';
      (f.options || []).forEach(function (o) {
        var sel = f.type === 'multi' ? (state[key] || []).indexOf(o.value) >= 0 : state[key] === o.value;
        var row = document.createElement('button'); row.type = 'button'; row.className = 'calc-mopt' + (sel ? ' on' : '');
        row.innerHTML = '<span>' + (o.label[locale] || o.value) + '</span><em>' + (o.add ? '+' + fmt(o.add) + ' MDL' : '') + '</em>';
        row.addEventListener('click', function () {
          if (f.type === 'multi') { var arr = state[key] || []; var i = arr.indexOf(o.value); if (i >= 0) arr.splice(i, 1); else arr.push(o.value); state[key] = arr; row.classList.toggle('on'); }
          else { state[key] = o.value; box.querySelectorAll('.calc-mopt').forEach(function (x) { x.classList.remove('on'); }); row.classList.add('on'); updateTile(key); render(); closeModal(); return; }
          updateTile(key); render();
        });
        box.appendChild(row);
      });
      modal.removeAttribute('hidden');
    }
    root.querySelectorAll('.calc-tile').forEach(function (tl) { tl.addEventListener('click', function () { openModal(tl.dataset.key); }); updateTile(tl.dataset.key); });
    modal.querySelector('.calc-modal-done').addEventListener('click', closeModal);
    modal.addEventListener('click', function (e) { if (e.target === modal) closeModal(); });

    function showStep(n) {
      step = Math.max(0, Math.min(totalSteps - 1, n));
      root.querySelectorAll('.calc-step').forEach(function (el) { el.style.display = Number(el.dataset.step) === step ? '' : 'none'; });
      document.getElementById(uid + '-stepno').textContent = step + 1;
      document.getElementById(uid + '-bar').style.width = ((step + 1) / totalSteps * 100) + '%';
      document.getElementById(uid + '-back').style.visibility = step === 0 ? 'hidden' : 'visible';
      document.getElementById(uid + '-next').style.display = step === totalSteps - 1 ? 'none' : '';
      root.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
    }
    document.getElementById(uid + '-next').addEventListener('click', function () { showStep(step + 1); });
    document.getElementById(uid + '-back').addEventListener('click', function () { showStep(step - 1); });

    var fileInput = document.getElementById(uid + '-file'), photosBox = document.getElementById(uid + '-photos');
    document.getElementById(uid + '-add-photo').addEventListener('click', function () { if (photos.length >= 6) return; fileInput.click(); });
    fileInput.addEventListener('change', function () {
      [].slice.call(fileInput.files).forEach(function (f) {
        if (photos.length >= 6 || !/^image\//.test(f.type)) return;
        var ph = document.createElement('div'); ph.className = 'calc-photo';
        // inline styles — scoped CSS doesn't reach runtime-created nodes, so fix the thumbnail size here
        ph.style.cssText = 'position:relative;width:88px;height:88px;border-radius:12px;overflow:hidden;background:#eef3fd;display:flex;align-items:center;justify-content:center;flex:none;color:#8a99b5;font-size:.8rem';
        ph.innerHTML = '<span>…</span>'; photosBox.appendChild(ph);
        var path = 'apartments/' + Date.now() + '-' + Math.random().toString(36).slice(2, 7) + '.' + (f.name.split('.').pop() || 'jpg').toLowerCase();
        fetch(SUPABASE_URL + '/storage/v1/object/calc-uploads/' + path, { method: 'POST', headers: { apikey: SUPABASE_KEY, Authorization: 'Bearer ' + SUPABASE_KEY, 'content-type': f.type, 'x-upsert': 'true' }, body: f })
          .then(function (r) { if (!r.ok) throw 0; var url = SUPABASE_URL + '/storage/v1/object/public/calc-uploads/' + path; photos.push(url); ph.innerHTML = '<img src="' + url + '" alt="" style="width:100%;height:100%;object-fit:cover;display:block"/><button type="button" class="calc-photo-x" style="position:absolute;top:3px;right:3px;width:20px;height:20px;border:0;border-radius:50%;background:rgba(12,41,89,.85);color:#fff;cursor:pointer;font-size:.7rem;line-height:1;display:flex;align-items:center;justify-content:center">✕</button>'; ph.querySelector('.calc-photo-x').addEventListener('click', function () { photos = photos.filter(function (u) { return u !== url; }); ph.remove(); }); })
          .catch(function () { ph.remove(); });
      });
      fileInput.value = '';
    });

    // phone mask: +373 XX XXX XXX (Moldova)
    var phEl = document.getElementById(uid + '-phone');
    function maskPhone() { var d = phEl.value.replace(/\D/g, ''); if (d.indexOf('373') === 0) d = d.slice(3); d = d.slice(0, 8); var out = '+373'; if (d.length) out += ' ' + d.slice(0, 2); if (d.length > 2) out += ' ' + d.slice(2, 5); if (d.length > 5) out += ' ' + d.slice(5, 8); phEl.value = out; }
    phEl.addEventListener('focus', function () { if (!phEl.value.trim()) phEl.value = '+373 '; });
    phEl.addEventListener('input', maskPhone);

    document.getElementById(uid + '-submit').addEventListener('click', function () {
      var nm = document.getElementById(uid + '-name').value.trim(), msg = document.getElementById(uid + '-msg');
      var phDigits = phEl.value.replace(/\D/g, '');
      if (!nm) { msg.textContent = t.need; msg.className = 'calc-msg err'; return; }
      if (phDigits.length !== 11) { msg.textContent = t.phoneBad; msg.className = 'calc-msg err'; return; }
      if (!document.getElementById(uid + '-consent').checked) { msg.textContent = t.consentNeed; msg.className = 'calc-msg err'; return; }
      msg.textContent = '…'; msg.className = 'calc-msg';
      var sel = {};
      cfg.fields.forEach(function (f) { var v = state[f.key];
        if (f.type === 'multi') { var arr = (v || []).map(function (val) { var o = f.options.find(function (x) { return x.value === val; }); return o ? (o.label[locale] || val) : val; }); if (arr.length) sel[f.label[locale] || f.key] = arr; }
        else if (f.type === 'select') { var o = (f.options || []).find(function (x) { return x.value === v; }); if (o) sel[f.label[locale] || f.key] = o.label[locale] || v; }
        else sel[f.label[locale] || f.key] = v; });
      sel[t.lift] = lift === 'yes' ? t.liftYes : t.liftNo;
      var cm = document.getElementById(uid + '-comment'); var comment = cm ? cm.value.trim() : '';
      fetch(SUPABASE_URL + '/rest/v1/site_leads', {
        method: 'POST', headers: { apikey: SUPABASE_KEY, Authorization: 'Bearer ' + SUPABASE_KEY, 'Content-Type': 'application/json', Prefer: 'return=minimal' },
        body: JSON.stringify({ project_id: PROJECT_ID, name: nm, phone: phEl.value, service: 'Калькулятор: ' + slug, notes: JSON.stringify({ selections: sel, estimate: compute() + ' MDL', comment: comment, photos: photos }), locale: locale, source_url: location.href }),
      }).then(function (r) {
        if (r.ok) {
          msg.textContent = t.ok; msg.className = 'calc-msg ok';
          fetch('/api/notify-lead', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name: nm, phone: phEl.value, service: 'Калькулятор: ' + slug, estimate: compute() + ' MDL', selections: sel, comment: comment, photos: photos, locale: locale, source_url: location.href }) }).catch(function () {});
        } else { msg.textContent = t.err; msg.className = 'calc-msg err'; }
      })
        .catch(function () { msg.textContent = t.err; msg.className = 'calc-msg err'; });
    });

    render(); showStep(0);
  })();
</script>

<style>
  .calc-head { text-align: center; margin: 0 auto 26px; }
  .calc-head h1, .calc-head h2 { color: #0c2959; margin: 0; }
  /* embedded on a service page: give the section real top/bottom padding and
     more air between the heading and the calculator so it doesn't look glued. */
  .calc-embedded { padding-top: 72px; padding-bottom: 72px; }
  .calc-embedded .calc-head { margin-bottom: 40px; }
  /* wider — fills the container (margins = page padding); columns equal height */
  .calc-layout { display: grid; grid-template-columns: 2.2fr 1fr; gap: 22px; align-items: stretch; }
  .calc-wizard { display: flex; flex-direction: column; background: #fff; border: 1px solid #dbe6fb; border-radius: 24px; box-shadow: 0 24px 60px rgba(12, 41, 89, .10); overflow: hidden; position: relative; }
  .calc-top { padding: 20px 28px 0; }
  .calc-stepno { color: #8a99b5; font-size: .85rem; font-weight: 700; margin-bottom: 8px; }
