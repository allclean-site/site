---
import type { Article, Locale } from '../lib/articles';

interface Props {
  locale: Locale;
  articles: Pick<Article, 'slug' | 'title' | 'excerpt' | 'cover_url' | 'created_at'>[];
}
const { locale, articles } = Astro.props;
const base = locale === 'ru' ? '/blog/' : '/ro/blog/';
const p = locale === 'ru' ? '' : '/ro';
const t =
  locale === 'ru'
    ? {
        label: 'Блог',
        h1: 'ПОЛЕЗНЫЕ СОВЕТЫ ДЛЯ ЧИСТОГО ДОМА',
        sub: 'Короткие и честные гиды о том, как поддерживать дом чистым, спокойным и под контролем — даже когда жизнь в городе превращается в хаос.',
        read: 'Читать статью',
        empty: 'Скоро здесь появятся статьи.',
        ctaH1: 'ВЫ ГОТОВЫ',
        ctaH2: 'К ПОЛНОЙ ЧИСТОТЕ?',
        ctaSub: 'Закажите проверенных клинеров, которые приезжают вовремя, работают с заботой и оставляют дом свежим.',
        book: 'Записаться на уборку',
        price: 'Смотреть цены',
      }
    : {
        label: 'Blog',
        h1: 'SFATURI UTILE PENTRU O CASĂ CURATĂ',
        sub: 'Ghiduri scurte și sincere despre cum să-ți menții casa curată, calmă și sub control — chiar și când viața în oraș devine agitată.',
        read: 'Citește articolul',
        empty: 'În curând vor apărea articole.',
        ctaH1: 'SUNTEȚI GATA',
        ctaH2: 'PENTRU CURĂȚENIE COMPLETĂ?',
        ctaSub: 'Rezervă curățători de încredere care vin la timp, lucrează cu grijă și îți lasă casa proaspătă.',
        book: 'Programează curățenia',
        price: 'Vezi prețuri',
      };
const fmt = (d: string) =>
  new Date(d).toLocaleDateString(locale === 'ru' ? 'ru-RU' : 'ro-RO', { day: 'numeric', month: 'long', year: 'numeric' });
---
<main class="main-wrapper">
  <section class="section_hero-blog">
    <div class="padding-global">
      <div class="w-layout-blockcontainer container-large w-container">
        <div style="opacity:1" class="headline_blog">
          <div data-wf--tag--variant="depth" class="master_label w-variant-9a59c277-b838-5a8e-f25e-39f9204dca4d">
            <div class="label-large">{t.label}</div>
          </div>
          <h1>{t.h1}</h1>
          <div class="subtext_blog">
            <p class="text-size-large">{t.sub}</p>
          </div>
        </div>
        <div class="blog w-dyn-list">
          {articles.length === 0 ? (
            <p class="text-size-large">{t.empty}</p>
          ) : (
            <div role="list" class="grid_blog w-dyn-items">
              {articles.map((a) => (
                <div role="listitem" class="w-dyn-item">
                  <a href={base + a.slug} class="link_article w-inline-block">
                    <div class="image-wrap_article">
                      {a.cover_url ? (
                        <img src={a.cover_url} loading="eager" alt={a.title} class="image_cover" />
                      ) : (
                        <div class="image_cover" style="background:#eef3fd"></div>
                      )}
                    </div>
                    <div class="article-card_bottom-tile">
                      <div class="text-wrap_article-card">
                        <div class="text-size-small">{fmt(a.created_at)}</div>
                        <div class="heading-style-h4">{a.title}</div>
                      </div>
                      <div button-tertiary="" class="cta_tertiary">
                        <div>{t.read}</div>
                        <div icon-tertiary="" class="icon_button-tertiary w-embed">
                          <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 16 16" fill="none">
                            <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="var(--_❇️-icon---icon-stroke)" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                        </div>
                      </div>
                    </div>
                  </a>
                </div>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
</main>
<section class="section_cta">
  <div class="padding-global">
    <div class="w-layout-blockcontainer container-large w-container">
      <div class="master_cta">
        <div class="content_cta">
          <h2>{t.ctaH1}<div>{t.ctaH2}</div></h2>
          <div class="subtext_cta">
            <p class="text-size-large">{t.ctaSub}</p>
          </div>
          <div class="button-group_center">
            <a href={p + '/book-cleaning'} button="" data-wf--cta-primary--variant="lift" class="cta_primary w-inline-block">
              <div class="button_text-mask">
                <div button-icon-right="" class="icon-wrap_button">
                  <div class="wrap_icon-btn">
                    <div class="icon_button w-embed">
                      <svg width="100%" height="100%" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M3.33337 8.00016H12.6667M12.6667 8.00016L8.00004 3.3335M12.6667 8.00016L8.00004 12.6668" stroke="currentColor" stroke-width="var(--_❇️-icon---icon-stroke)" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </div>
                  </div>
                </div>
                <div button-text="" class="text-button">{t.book}</div>
              </div>
              <div button-bg="" class="btn-bg w-variant-f3c49ac3-5f19-afad-90be-3c82d51179b6"></div>
            </a>
            <a href={p + '/pricing'} button="" data-wf--cta-primary--variant="secondary" class="cta_primary w-variant-1ff8d96e-78cc-eac8-de90-206ecdaded5f w-inline-block">
              <div class="button_text-mask">
                <div button-icon-right="" class="icon-wrap_button">
                  <div class="wrap_icon-btn">
                    <div class="icon_button w-embed">
                      <svg width="100%" height="100%" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M3.33337 8.00016H12.6667M12.6667 8.00016L8.00004 3.3335M12.6667 8.00016L8.00004 12.6668" stroke="currentColor" stroke-width="var(--_❇️-icon---icon-stroke)" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </div>
                  </div>
                </div>
                <div button-text="" class="text-button">{t.price}</div>
              </div>
              <div button-bg="" class="btn-bg w-variant-1ff8d96e-78cc-eac8-de90-206ecdaded5f"></div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
