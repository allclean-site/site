                    </svg>
                  </div>
                </div>
                <div class="text-wrap_feature-card">
                  <div class="text-size-large text_body-bold">
                    Лучший сервис 2025
                  </div>
                  <div>Доверие клиентов и партнёров</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
