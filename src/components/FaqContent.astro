                </div>
                <div class="text-wrap_feature-card">
                  <div class="text-size-large text_body-bold">
                    1200+ постоянных клиентов
                  </div>
                  <div>По всему Кишинёву и пригородам.</div>
                </div>
              </div>
              <div class="card_feature">
                <div class="icon-wrap_feature">
                  <div class="icon-feature w-embed">
