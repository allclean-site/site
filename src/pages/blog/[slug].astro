---
export const prerender = false;
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogPostContent from '../../components/BlogPostContent.astro';
import { getArticle, counterpartSlug } from '../../lib/articles';
import { buildBreadcrumbJsonLd } from '../../lib/breadcrumbs.ts';

const { slug } = Astro.params;
const article = await getArticle('ru', slug!);
if (!article) return new Response('Статья не найдена', { status: 404 });

Astro.response.headers.set('Cache-Control', 's-maxage=300, stale-while-revalidate=3600');
const otherSlug = await counterpartSlug(article.group_id, 'ro');
const site = Astro.site ?? new URL('https://allclean.md');
const ruUrl = new URL('/blog/' + article.slug, site).href;
const roUrl = otherSlug ? new URL('/ro/blog/' + otherSlug, site).href : ruUrl;
const desc = article.seo_description || article.excerpt || '';
const breadcrumbs = buildBreadcrumbJsonLd(site.href.replace(/\/$/, ''), [
  { name: 'Главная', path: '/' },
  { name: 'Блог', path: '/blog' },
  { name: article.title, path: '/blog/' + article.slug },
]);
---
<Base
  title={article.seo_title || article.title}
  description={desc}
  lang="ru"
  ruAlternate={ruUrl}
  roAlternate={roUrl}
>
  <Fragment slot="head">
    {article.jsonld && <script type="application/ld+json" set:html={JSON.stringify(article.jsonld)} is:inline />}
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbs)} is:inline />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={article.seo_title || article.title} />
    {desc && <meta property="og:description" content={desc} />}
    {article.cover_url && <meta property="og:image" content={article.cover_url} />}
  </Fragment>
  <div class="page-wrapper">
    <Header altHref={roUrl} />
    <BlogPostContent article={article} locale="ru" />
    <Footer altHref={roUrl} />
  </div>
</Base>
