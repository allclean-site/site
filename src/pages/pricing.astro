---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Content from '../components/PricingContent.astro';
import { buildBreadcrumbJsonLd } from '../lib/breadcrumbs.ts';

const site = (Astro.site ?? new URL('https://allclean.md')).href.replace(/\/$/, '');
const breadcrumbs = buildBreadcrumbJsonLd(site, [
  { name: 'Главная', path: '/' },
  { name: 'Цены', path: '/pricing' },
]);
---
<Base title="Цены на уборку — AllClean Кишинёв" description="Прозрачные цены на уборку квартир и домов в Кишинёве. Никаких скрытых платежей — стоимость известна заранее." lang="ru">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbs)} />
  <div class="page-wrapper">
    <Header />
    <Content locale="ru" />
    <Footer />
  </div>
</Base>
