---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Features from '../components/Features.astro';
import Testimonials from '../components/Testimonials.astro';
import CalculatorPicker from '../components/CalculatorPicker.astro';
import HowItWorks from '../components/HowItWorks.astro';
import AboutSection from '../components/AboutSection.astro';
import Faq from '../components/Faq.astro';
import CtaSection from '../components/CtaSection.astro';
import FeaturesBottom from '../components/FeaturesBottom.astro';
import Footer from '../components/Footer.astro';
---
<Base
  title="AllClean — уборка квартир и домов в Кишинёве"
  description="Профессиональная клининговая служба в Кишинёве: уборка квартир, домов и офисов. Прозрачные цены, онлайн-запись."
  lang="ru"
>
  <div class="page-wrapper">
    <Header />
    <main class="main-wrapper">
      <Hero />
      <Services />
      <Features />
      <Testimonials />
      <CalculatorPicker locale="ru" />
      <HowItWorks />
      <AboutSection />
      <Faq />
      <CtaSection />
      <FeaturesBottom />
    </main>
    <Footer />
  </div>
</Base>
