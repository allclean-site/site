---
export const prerender = false;
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BlogContent from '../components/BlogContent.astro';
import { listArticles } from '../lib/articles';
import { buildBreadcrumbJsonLd } from '../lib/breadcrumbs.ts';

const articles = await listArticles('ru');
// SSR page (fetches from Supabase) was never edge-cached — every hit took a 2s+
// TTFB round trip. Let Vercel's CDN serve a cached copy and revalidate in the
// background instead of blocking every visitor on a fresh Supabase fetch.
Astro.response.headers.set('Cache-Control', 's-maxage=300, stale-while-revalidate=3600');
const site = (Astro.site ?? new URL('https://allclean.md')).href.replace(/\/$/, '');
const breadcrumbs = buildBreadcrumbJsonLd(site, [
  { name: 'Главная', path: '/' },
  { name: 'Блог', path: '/blog' },
]);
---
<Base
  title="Блог — советы по уборке | All Clean Кишинёв"
  description="Полезные статьи об уборке дома и офиса, лайфхаки и советы от клининговой службы All Clean в Кишинёве."
  lang="ru"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbs)} />
  <div class="page-wrapper">
    <Header />
    <BlogContent locale="ru" articles={articles} />
    <Footer />
  </div>
</Base>
