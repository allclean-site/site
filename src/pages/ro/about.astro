---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Content from '../../components/AboutContent.astro';
import { buildBreadcrumbJsonLd } from '../../lib/breadcrumbs.ts';

const site = (Astro.site ?? new URL('https://allclean.md')).href.replace(/\/$/, '');
const breadcrumbs = buildBreadcrumbJsonLd(site, [
  { name: 'Acasă', path: '/ro' },
  { name: 'Despre noi', path: '/ro/about' },
]);
---
<Base title="Despre noi — AllClean Chișinău" description="AllClean — serviciu de curățenie în Chișinău. Case curate, minți liniștite. Curățenie făcută de oameni cărora le pasă." lang="ro">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbs)} />
  <div class="page-wrapper">
    <Header lang="ro" />
    <Content />
    <Footer lang="ro" />
  </div>
</Base>
