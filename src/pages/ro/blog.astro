---
export const prerender = false;
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogContent from '../../components/BlogContent.astro';
import { listArticles } from '../../lib/articles';
import { buildBreadcrumbJsonLd } from '../../lib/breadcrumbs.ts';

const articles = await listArticles('ro');
Astro.response.headers.set('Cache-Control', 's-maxage=300, stale-while-revalidate=3600');
const site = (Astro.site ?? new URL('https://allclean.md')).href.replace(/\/$/, '');
const breadcrumbs = buildBreadcrumbJsonLd(site, [
  { name: 'Acasă', path: '/ro' },
  { name: 'Blog', path: '/ro/blog' },
]);
---
<Base
  title="Blog — sfaturi de curățenie | All Clean Chișinău"
  description="Articole utile despre curățenia casei și a biroului, trucuri și sfaturi de la serviciul de curățenie All Clean din Chișinău."
  lang="ro"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbs)} />
  <div class="page-wrapper">
    <Header lang="ro" />
    <BlogContent locale="ro" articles={articles} />
    <Footer lang="ro" />
  </div>
</Base>
