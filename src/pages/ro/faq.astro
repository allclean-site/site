---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Content from '../../components/FaqContent.astro';
import { faqRo, buildFaqJsonLd } from '../../data/faq.ts';
import { buildBreadcrumbJsonLd } from '../../lib/breadcrumbs.ts';

const site = (Astro.site ?? new URL('https://allclean.md')).href.replace(/\/$/, '');
const jsonld = buildFaqJsonLd(faqRo);
const breadcrumbs = buildBreadcrumbJsonLd(site, [
  { name: 'Acasă', path: '/ro' },
  { name: 'Întrebări frecvente', path: '/ro/faq' },
]);
---
<Base title="Întrebări frecvente — AllClean Chișinău" description="Răspunsuri la întrebări frecvente despre curățenie: prețuri, servicii, programare, plată. Serviciul AllClean în Chișinău." lang="ro">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonld)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbs)} />
  <div class="page-wrapper">
    <Header lang="ro" />
    <Content />
    <Footer lang="ro" />
  </div>
</Base>
