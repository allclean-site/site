---
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ServiceLanding from '../../../components/ServiceLanding.astro';
import { SERVICES, getService, buildServiceJsonLd } from '../../../data/services';
import { getCalculator } from '../../../lib/calculators';

export function getStaticPaths() {
  return SERVICES.map((s) => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const service = getService(slug!)!;
const calc = await getCalculator(service.calcSlug);
const L = service.ro;
const SITE = 'https://allclean.md';
const jsonld = buildServiceJsonLd(service, 'ro', SITE);
---
<Base
  title={L.metaTitle}
  description={L.metaDescription}
  lang="ro"
  ruAlternate={`${SITE}/services/${slug}`}
  roAlternate={`${SITE}/ro/services/${slug}`}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonld)} />
  <div class="page-wrapper">
    <Header lang="ro" />
    <ServiceLanding service={service} calc={calc} locale="ro" />
    <Footer lang="ro" />
  </div>
</Base>
