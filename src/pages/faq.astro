---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Content from '../components/FaqContent.astro';
import { faqRu, buildFaqJsonLd } from '../data/faq.ts';
import { buildBreadcrumbJsonLd } from '../lib/breadcrumbs.ts';

const site = (Astro.site ?? new URL('https://allclean.md')).href.replace(/\/$/, '');
const jsonld = buildFaqJsonLd(faqRu);
const breadcrumbs = buildBreadcrumbJsonLd(site, [
  { name: 'Главная', path: '/' },
  { name: 'Вопросы и ответы', path: '/faq' },
]);
---
<Base title="Вопросы и ответы — AllClean Кишинёв" description="Ответы на частые вопросы об уборке: цены, услуги, бронирование, оплата. Клининговая служба AllClean в Кишинёве." lang="ru">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonld)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbs)} />
  <div class="page-wrapper">
    <Header />
    <Content />
    <Footer />
  </div>
</Base>
